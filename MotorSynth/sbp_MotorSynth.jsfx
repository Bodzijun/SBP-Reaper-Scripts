cur_throttle = 0;
phase_acc = 0;

// DC blocker
dc_pole = 0.995;
dc_in = dc_out = 0;

// Triggers for BOV and Crackle passed from block
bov_burst = 0;
crackle_burst = 0;
prev_target_throttle = 0;
prev_target_ignition = slider1 | 0;

@slider
// Convert slider mappings
target_mode = slider4;
  target_rpm = slider10;
  target_throttle = slider2 / 100;
  target_cylinders = slider12 == 0 ? 1 : slider12 == 1 ? 2 : slider12 == 2 ? 3 : slider12 == 3 ? 4 : slider12 == 4 ? 6 : 8;
  target_size = slider13 / 100;
  target_character = slider14 / 100;
  target_roughness = slider15 / 100;
  cold_start = slider16 / 100;
  limiter_rpm = slider11;
  manual_gear = slider7;
  // Slot 8 = Park/N: permanent neutral for idle testing, no auto-engage ever
  n_hold_mode = manual_gear == 8 ? 1 : 0;
  reverse_mode = manual_gear == 7 ? 1 : 0;
  phys_gear_val = n_hold_mode ? 0 : (reverse_mode ? -1 : manual_gear);
  slider_init_done ? (
    manual_gear_changed = manual_gear != prev_slider_gear;
  ) : (
    manual_gear_changed = 0;
  );
  // Suppress shift sounds when transitioning to/from Park/N (no mechanical jolt)
  (manual_gear == 8 || prev_slider_gear == 8) ? manual_gear_changed = 0;
  manual_gear_changed ? (
    ignore_slider_gear_event ? (
      // Host callback after internal auto-shift sync: keep gear sync, no duplicate clank
      ignore_slider_gear_event = 0;
      target_gear = phys_gear_val;
    ) : engine_state == 2 ? (
      prev_phys = prev_slider_gear == 8 ? 0 : (prev_slider_gear == 7 ? -1 : prev_slider_gear);
      manual_delta = abs(phys_gear_val - prev_phys);
      n_to_first = prev_phys == 0 && phys_gear_val == 1;
      n_to_first ? (
        // N -> 1 should feel like a short, heavy "clunk" with minimal scrape tail
        shift_jolt_pulse_env = max(shift_jolt_pulse_env, 1.22 + target_size * 0.25);
        shift_jolt_hit2_pending = 1;
        shift_jolt_hit2_manual = 1;
        shift_jolt_hit2_cnt = max(1, (srate * 0.165) | 0);
        shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 1.52 + target_size * 0.20);
        shift_scrape_env = max(shift_scrape_env, 0.72 + target_size * 0.12);
        shift_scrape_burst = max(shift_scrape_burst, 5 + (target_size * 3)|0);
      ) : (
        // Manual shift "ta-DA": softer first hit, stronger delayed second hit
        shift_jolt_pulse_env = max(shift_jolt_pulse_env, 0.95 + manual_delta * 0.18);
        shift_jolt_hit2_pending = 1;
        shift_jolt_hit2_manual = 1;
        shift_jolt_hit2_cnt = max(1, (srate * 0.300) | 0);
        shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 1.28 + manual_delta * 0.12);
        shift_scrape_env = max(shift_scrape_env, 1.0 + manual_delta * 0.4);
        shift_scrape_burst = max(shift_scrape_burst, 9 + (manual_delta * 4)|0);
      );
      target_gear = phys_gear_val;
    ) : (
      target_gear = phys_gear_val;
    );
  );
  gear = phys_gear_val;
  prev_slider_gear = manual_gear;
  slider_init_done = 1;
  target_mech = slider17 / 100;
  target_turbo = slider23 / 100;
  target_intake = slider24 / 100;
  target_whine = slider18 / 100;
  target_shift_jolt = slider19 / 100;
  target_shift_scrape = slider20 / 100;
  target_road = slider30 / 100;
  exhaust_type = slider21;
  target_muffler = slider22 / 100;
  target_crackle = slider25 / 100;
  target_als = slider26 / 100;
  target_drive = slider35 / 100;
  target_tone = slider36 / 100;
  width = slider37 / 100;
  vol_amp = 10 ^ (slider38 / 20);
  target_ignition = slider1;
  out_exhaust = slider39 * 2;
  out_mech = slider41 * 2;
  out_air = slider43 * 2;
  out_bov = slider44 * 2;
  out_gearbox = slider42 * 2;
  out_road = slider45 * 2;
  out_chassis = slider46 * 2;
  out_engine = slider40 * 2;
  out_brakes = slider47 * 2;
  out_bangs = slider48 * 2;
  target_wind = slider34 / 100;
  out_wind = slider49 * 2;
  out_interior = slider62 * 2;
  rev_beep_pitch = slider60;
  rev_beep_level = slider61 / 100;
  target_ind_mode = slider63 | 0;
  target_ind_level = slider64 / 100;
  target_cabin_amb = slider65 / 100;
  target_ind_type = slider66 | 0;
  target_turn_infl = slider67 / 100;
  target_handbrake = slider68 / 100;
  target_hb_ratchet = slider69 / 100;
  target_hb_release = slider70 / 100;
  target_hb_hold = slider71 / 100;
  target_gb_mesh = slider72 / 100;
  target_gb_diff = slider73 / 100;
  target_shift_peak = slider74 / 100;
  target_sci_mode = slider75 | 0;
  target_ev_whine = slider76 / 100;
  target_inverter = slider77 / 100;
  target_regen = slider78 / 100;
  target_hybrid_bias = slider79 / 100;
  target_siren_on = slider80 | 0;
  target_siren_type = slider81 | 0;
  target_siren_level = slider82 / 100;
  target_horn_on = slider83 | 0;
  target_horn_level = slider84 / 100;
  out_siren_horn = slider85 * 2;
  target_idle_pop = slider86 / 100;
  target_fuel_pump = slider87 / 100;
  target_knock_ping = slider88 / 100;
  target_regen_timbre = slider89 / 100;
  target_shift_intent_mode = slider6 | 0;
  target_trans_mode = slider5 | 0;
  target_cabext = slider9 / 100;
  target_drift_aggr = slider32 / 100;
  target_veh_speed_override = slider8 / 280.0;  // 0 = Auto, >0 = manual km/h normalised 0..1
  target_chorus_color = slider33 / 100;
  target_brake = slider3 / 100;
  target_brake_squeal = slider27 / 100;
  target_brake_trim = 10 ^ (slider29 / 20);
  target_brake_overtone = slider28 / 100;
  target_pad_squeak = slider53 / 100;
  target_brake_pitch = slider54 / 100;
  target_backfire_body = slider55 / 100;
  target_backfire_res = slider56 / 100;
  target_valve = slider57 / 100;
  target_belt = slider58 / 100;
  target_chain = slider59 / 100;
  target_chassis = target_road;
  surface_type = slider31 | 0;

// Gear ratios for transmission whine
gear_ratio = get_gear_ratio(gear);

// Setup firing table
target_cylinders == 1 ? ( active_offsets[0]=0; ) :
target_cylinders == 2 ? ( active_offsets[0]=0; active_offsets[1]=0.5; ) :
target_cylinders == 3 ? ( active_offsets[0]=0; active_offsets[1]=0.3333; active_offsets[2]=0.6666; ) :
target_cylinders == 4 ? ( 
  active_offsets[0]=0; active_offsets[1]=0.25; active_offsets[2]=0.75; active_offsets[3]=0.5; 
) :
target_cylinders == 6 ? ( 
  active_offsets[0]=0; active_offsets[1]=0.1666; active_offsets[2]=0.3333; 
  active_offsets[3]=0.6666; active_offsets[4]=0.5; active_offsets[5]=0.8333;
) : 
(
  active_offsets[0]=0; active_offsets[1]=0.125; active_offsets[2]=0.375; active_offsets[3]=0.25;
  active_offsets[4]=0.625; active_offsets[5]=0.75; active_offsets[6]=0.875; active_offsets[7]=0.5;
);

// Exotic Exhaust preseting (Lowered feedback to prevent flanger ringing)
exhaust_type == 0 ? ( target_pipe_len = 0.015; exhaust_fb = 0.15; exhaust_damp = 0.4; ) : // Stock
exhaust_type == 1 ? ( target_pipe_len = 0.008; exhaust_fb = 0.25; exhaust_damp = 0.5; ) : // Sport
( target_pipe_len = 0.003; exhaust_fb = 0.35; exhaust_damp = 0.7; ); // Straight Pipe
pipe_samps = max(10, floor(target_pipe_len * srate * 2.0)); // Roundtrip MS converted

// Recompute muffler filter safely
// More physical curve: less extreme top-end when muffler is open
muffler_open = 1.0 - target_muffler;
muffler_freq = 360 + pow(muffler_open, 1.55) * 4200;
muffler_filter.biquad_lpf(muffler_freq, 0.707);

@block

// Ignition State Machine
engine_state == 0 && target_ignition == 1 ? (
  shutoff_seq_active = 0;
  // Turn Engine ON
  cold_start > 0.05 ? (
    // Cold start mode
    engine_state = 1; // Cranking
    starter_timer = cold_start * 2.0; // 0.1 to 2 seconds based on slider
    starter_phase = 0;
    cur_rpm = 250; // Initial cranking speed
  ) : (
    // Instant start (warm)
    engine_state = 2; // Running
    cur_rpm = 800; // Jump to idle
  );
) : engine_state == 1 && target_ignition == 1 ? (
  // Currently Cranking
  starter_timer -= (samplesblock / srate); // timer decrement
  starter_timer <= 0.0 ? (
    engine_state = 2; // Caught! Running
    // Keep near cranking RPM; post-start flare wave drives revs organically
    cur_rpm = 265 + rand(40);
    post_start_nrevs    = 1 + (rand(2)|0) + (target_size > 0.55 ? 1 : 0); // 1..3 (larger engine = more revs)
    post_start_idle_dur = (0.38 + target_size * 0.22) * post_start_nrevs + cold_start * 0.9;
    post_start_idle_timer = post_start_idle_dur;
  ) : (
    // Modulate cranking RPM with compression resistance
    comp_freq = target_cylinders * 0.5;
    cur_rpm = 250 + sin(starter_phase * pi2 * comp_freq) * 40; 
    // Randomly "catch" a tiny bit towards the end to simulate starting
    starter_timer < cold_start ? cur_rpm += rand(150);
  );
) : target_ignition == 0 ? ( // Shut off sequence
  shutoff_seq_active == 0 && engine_state > 0 ? (
    // One-shot shutdown sputter burst; larger engines cough longer/heavier
    shutoff_seq_active = 1;
    shutoff_pop_left = 2 + (target_size * 3.0) | 0;
    shutoff_pop_env = max(shutoff_pop_env, 0.35 + target_size * 0.35);
    shutoff_pop_gap = max(1, (srate * (0.028 + abs(rand_noise()) * 0.020)) | 0);
  );
  engine_state = 0;
  // Longer release while rolling, shorter when nearly stationary
  stop_speed_ref = max(speed_display_norm, coast_speed_norm);
  stop_release_sec = 0.55 + pow(min(max(stop_speed_ref, 0.0), 1.0), 0.90) * 3.80;
);

// Phase 8: fuel pump priming buzz on ignition rising edge.
target_ignition == 1 && prev_target_ignition == 0 ? (
  fuel_pump_timer = max(1, (srate * (0.18 + target_fuel_pump * 0.90)) | 0);
);
prev_target_ignition = target_ignition;

// Throttle override: Allow sputtering and "coughs" during cranking
engine_state == 0 ? (
  eff_throttle = 0;
) : engine_state == 1 ? (
  // Sputtering pulses to simulate cylinders barely firing
  rand_noise() > 0.8 ? sputter_t = 0.15 + abs(rand_noise()) * 0.15 : sputter_t *= 0.8;
  eff_throttle = sputter_t;
) : shift_timer > 0 ? (
  // Clutch pressed during shift.
  // Blip amount is chosen when the shift starts: soft downshift vs kickdown.
  eff_throttle = target_gear < gear ? (shift_intent_dir == -2 ? shift_blip_hold : 0.0) : 0.0;
) : post_start_idle_timer > 0 ? (
  // Post-start flare active: ignore user throttle so the RPM override below runs cleanly
  eff_throttle = 0.0;
) : (
  eff_throttle = target_throttle;
);

// Thermal warm-up model: engine accumulates heat while running, cools when off
engine_state == 2 ? (
  therm_up_tc = 1.0 - exp(-(samplesblock / srate) / 45.0);  // ~45s to full hot
  thermal_norm += (1.0 - thermal_norm) * therm_up_tc;
) : engine_state == 0 ? (
  therm_dn_tc = 1.0 - exp(-(samplesblock / srate) / 90.0);  // ~90s to full cold
  thermal_norm *= (1.0 - therm_dn_tc);
);
thermal_norm = min(max(thermal_norm, 0.0), 1.0);
cold_fact = 1.0 - thermal_norm;

// Disable base idle if engine is turned off; cold idle ~280 RPM higher
base_idle_rpm = engine_state == 2 ? (800.0 + cold_fact * 280.0) : 0.0;

// Compute RPM physics if in physics mode, else smooth directly
cur_throttle = smooth_param(eff_throttle, cur_throttle, 50);

// Throttle drop detection for BOV & Crackle
// Detection MUST happen on the user-input target to catch fast mouse/MIDI drops.
// Threshold increased to -0.15 (15% drop in one frame) to prevent jitter when dragging slowly
throttle_delta = target_throttle - prev_target_throttle;
throttle_delta < -0.15 && prev_target_throttle > 0.3 ? (
  // Compressor overpump burst on fast pedal lift
  drop_rpm_norm = min(max((cur_rpm - base_idle_rpm) / 3600.0, 0.0), 1.0);
  turbo_overpump_env = max(turbo_overpump_env, (0.16 + target_turbo * 0.36) * (0.40 + drop_rpm_norm * 0.60));
  bov_burst += target_turbo * 1.5;
  crackle_burst += (target_crackle * 5.0) + (target_als * 15.0); // Queue massive crackles instantly with ALS
);

// Gearbox direction intent.
// -2 = kickdown, -1 = soft downshift, +1 = cruise/upshift bias, 0 = neutral.
shift_intent_timer > 0 ? shift_intent_timer -= (samplesblock / srate);
shift_intent_dir = 0;
engine_state == 2 && target_mode == 1 ? (
  target_shift_intent_mode == 1 ? (
    shift_intent_timer = 0.0;
    shift_intent_dir = 1;
  ) : target_shift_intent_mode == 2 ? (
    shift_intent_timer = 0.0;
    shift_intent_dir = 0;
  ) : target_shift_intent_mode == 3 ? (
    shift_intent_timer = 0.0;
    shift_intent_dir = -1;
  ) : target_shift_intent_mode == 4 ? (
    shift_intent_timer = 0.0;
    shift_intent_dir = -2;
  ) : (
    kickdown_rpm_gate = min(target_rpm * 0.72, limiter_rpm * 0.62);
    recover_rpm_gate = min(target_rpm * 0.80, limiter_rpm * 0.70);
    throttle_delta > 0.12 && target_throttle > 0.55 && gear > 1 && cur_rpm < kickdown_rpm_gate ? (
      shift_intent_timer = 0.85;
    );
    shift_intent_timer > 0 && target_throttle > 0.45 && gear > 1 && cur_rpm < recover_rpm_gate ? (
      shift_intent_dir = -2;
    ) : target_throttle < 0.45 || cur_rpm > target_rpm - 220 ? (
      shift_intent_dir = 1;
    );
  );
);
prev_target_throttle = target_throttle;
engine_brake_map = 0.0;

target_mode == 0 ? (
  // Legacy / Direct Control
  engine_state == 2 ? (
    // In Direct mode, pedal controls RPM span from idle to RPM Target
    direct_thr = max(0.0, min(target_throttle, 1.0));
    // For pickup use a slight curve, for release keep linear so RPM falls immediately
    direct_pedal_up = pow(direct_thr, 0.60);
    direct_target_up = direct_min_rpm + direct_pedal_up * (direct_max_rpm - direct_min_rpm);
    // Small dead-zone at the bottom to force clean return to idle when pedal is released
    direct_thr < 0.02 ? direct_target_rpm = direct_min_rpm;

    // Block-aware slew (this section runs in @block, not @sample)
    direct_coeff = 1.0 - exp(-dt_block / max(0.0005, direct_tc));
    cur_rpm += (direct_target_rpm - cur_rpm) * direct_coeff;
  );
) : (
  // Intuitive Physics Model
  engine_state == 2 ? (
    // Calculate target RPM based on throttle and gear load. We use 1/gear_ratio because smaller ratios (higher gears) burden the engine more.
    target_rpm_phys = base_idle_rpm + (eff_throttle * (limiter_rpm + 1500.0)) - (gear > 0 ? (1.0 / gear_ratio) * 1000.0 * eff_throttle : 0.0);

    // Approach target with inertia (Flywheel simulation)
    flywheel_speed_mult = 1.0 - (target_size * 0.75); // 1.0 down to 0.25
    
    // Base acceleration lowered to slow down the gear climbing
    // 1st Gear (ratio ~3.1) -> ~0.03 (Fast). 6th (ratio ~0.5) -> ~0.005 (Slow)
    base_accel = gear > 0 ? 0.012 * gear_ratio : 0.04;

    // Nonlinear engine-brake map on closed throttle:
    // stronger in low gears, weaker in high gears, and grows with RPM band.
    closed_thr = min(max((0.14 - eff_throttle) / 0.14, 0.0), 1.0);
    closed_thr2 = closed_thr * closed_thr;
    gear_idx_norm = gear > 0 ? min(max((gear - 1) / 5.0, 0.0), 1.0) : 1.0;
    gear_brake_curve = pow(1.0 - gear_idx_norm, 1.25);
    rpm_brake_norm = min(max((cur_rpm - base_idle_rpm) / max(limiter_rpm - base_idle_rpm, 1.0), 0.0), 1.0);
    rpm_brake_curve = 0.20 + pow(rpm_brake_norm, 0.80) * 0.80;
    engine_brake_map = gear > 0 ? (closed_thr2 * (0.10 + gear_brake_curve * 0.90) * rpm_brake_curve) : 0.0;
    base_decel = 0.020 + engine_brake_map * 0.085;
    
    inertia_speed = cur_rpm < target_rpm_phys ? (base_accel * flywheel_speed_mult) : (base_decel * flywheel_speed_mult);
    
    cur_rpm += (target_rpm_phys - cur_rpm) * inertia_speed;
    shift_cooldown -= (samplesblock / srate);

    // N→D auto-engage: press throttle from Neutral → auto-slip into 1st gear (D/S modes only)
    // n_hold_mode (Park/N slot 7) locks out auto-engage for idle testing
    gear == 0 && n_hold_mode == 0 && target_trans_mode != 2 && shift_timer <= 0 && eff_throttle > 0.08 ? (
      gear = 1;
      target_gear = 1;
      gear_ratio = get_gear_ratio(1);
      ignore_slider_gear_event = 1;
      slider7 = 1;
      sliderchange(1 << 6);
      shift_jolt_pulse_env = max(shift_jolt_pulse_env, 0.90 + target_size * 0.15);
      shift_jolt_hit2_pending = 1;
      shift_jolt_hit2_manual = 1;
      shift_jolt_hit2_cnt = max(1, (srate * 0.140) | 0);
      shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 1.10 + target_size * 0.12);
      shift_scrape_env = max(shift_scrape_env, 0.62 + target_size * 0.10);
      shift_scrape_burst = max(shift_scrape_burst, 5);
      shift_cooldown = 0.45;
    );

    gear > 0 ? (
      shift_timer > 0 ? (
        shift_timer -= (samplesblock / srate);
        
        // Calculate vehicle wheel speed from current gear
        cur_ratio = get_gear_ratio(gear);
        next_ratio = get_gear_ratio(target_gear);
        cur_wheel_speed = cur_rpm / max(cur_ratio, 0.01);
        
        // expected RPM of the next gear given same wheel speed
        expected_rpm = cur_wheel_speed * next_ratio;
        // Transition to expected RPM.
        // Soft Downshift mode intentionally avoids pre-rev during clutch phase.
        shift_match_coeff = target_gear < gear ? (shift_intent_dir == -2 ? 0.15 : (shift_intent_dir == -1 ? 0.0 : 0.06)) : 0.15;
        cur_rpm += (expected_rpm - cur_rpm) * shift_match_coeff;
        
        shift_timer <= 0 ? (
          gear = target_gear;
          ignore_slider_gear_event = 1;
          slider7 = gear;
          sliderchange(1 << 6);
          gear_ratio = next_ratio;
          shift_blip_hold = 0.0;
          // Mechanical clank on gear engage
          mech_lpf -= 3.0; // Sharp pop of noise
          shift_jolt_pulse_env = max(shift_jolt_pulse_env, 1.38);
          shift_jolt_hit2_pending = 1;
          shift_jolt_hit2_manual = 0;
          shift_jolt_hit2_cnt = max(1, (srate * (0.052 - eff_throttle * 0.010)) | 0);
          shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 0.70 + eff_throttle * 0.20);
          shift_scrape_env = max(shift_scrape_env, 0.80 + eff_throttle * 0.55);
          shift_scrape_burst = max(shift_scrape_burst, 10 + (eff_throttle * 8)|0);
          shift_cooldown = max(0.35, shift_cooldown_next);
          shift_cooldown_next = 1.0;
        );
      ) : shift_cooldown <= 0 && target_trans_mode != 2 ? (
        // Auto shift UP at RPM Target (limiter_rpm = hard redline/cutoff only)
        auto_speed_kmh = speed_norm_raw * 280.0;
        upshift_speed_gate = gear == 1 ? 24.0 : gear == 2 ? 40.0 : gear == 3 ? 62.0 : gear == 4 ? 88.0 : 112.0;
        // D shifts a bit earlier, S later and sportier.
        target_trans_mode == 0 ? (
          upshift_speed_gate -= 5.0;
        ) : target_trans_mode == 1 ? (
          upshift_speed_gate += 9.0;
        );
        // Shift intent additionally biases the speed gate.
        target_shift_intent_mode == 1 ? upshift_speed_gate -= 4.0;
        (target_shift_intent_mode == 3 || target_shift_intent_mode == 4) ? upshift_speed_gate += 6.0;
        upshift_rpm_gate = target_shift_intent_mode == 1 ? (target_rpm - 420)
          : (target_shift_intent_mode == 3 || target_shift_intent_mode == 4) ? (target_rpm + 420)
          : (target_rpm - 80);
        upshift_thr_gate = target_shift_intent_mode == 1 ? 0.18 : 0.3;
        target_trans_mode == 0 ? (
          // D mode: a little earlier, but keep close to target
          upshift_rpm_gate -= 60;
          upshift_thr_gate = max(0.16, upshift_thr_gate - 0.05);
        ) : target_trans_mode == 1 ? (
          // S mode: slightly later than D, but no large delay over target
          upshift_rpm_gate += 80;
          upshift_thr_gate = min(0.85, upshift_thr_gate + 0.08);
        );
        upshift_rpm_gate = min(upshift_rpm_gate, target_rpm + 120);
        rpm_force_upshift = cur_rpm >= (target_rpm + 160);
        speed_ready = auto_speed_kmh >= upshift_speed_gate || rpm_force_upshift;
        cur_rpm >= upshift_rpm_gate && speed_ready && eff_throttle > upshift_thr_gate && gear < 6 && shift_intent_dir >= 0 ? (
          target_gear = gear + 1;
          shift_timer = 0.25; // 250ms shift duration
          shift_blip_hold = 0.0;
          // Normalize auto behavior: lower throttle = longer dwell between shifts
          shift_cooldown_next = 0.70 + (1.0 - eff_throttle) * 2.10;
          bov_burst += target_turbo * 2.5; // Blow-off valve
          crackle_burst += target_crackle * 4.0; // Exhaust pop
          mech_lpf += 2.0; // Clank out of gear
          shift_jolt_pulse_env = max(shift_jolt_pulse_env, 1.05 + eff_throttle * 0.32);
          shift_jolt_hit2_pending = 1;
          shift_jolt_hit2_manual = 0;
          shift_jolt_hit2_cnt = max(1, (srate * (0.045 - eff_throttle * 0.008)) | 0);
          shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 0.62 + eff_throttle * 0.20);
          shift_scrape_env = max(shift_scrape_env, 1.00 + eff_throttle * 0.40);
          shift_scrape_burst = max(shift_scrape_burst, 11 + (eff_throttle * 8)|0);
        );
        // Auto shift DOWN when bogged down or on deliberate downshift intent.
        // Gear-specific hysteresis avoids hunting; target_rpm steers requested working band.
        base_downshift_rpm = gear == 6 ? 1450 : 1800;
        base_downshift_thr = gear == 6 ? 0.72 : 0.40;
        soft_downshift_rpm = max(base_downshift_rpm, min(target_rpm * 0.62, limiter_rpm * 0.72));
        soft_downshift_thr = 0.02;
        kickdown_downshift_rpm = max(base_downshift_rpm, min(target_rpm * 0.46, 2550));
        kickdown_downshift_thr = gear == 6 ? 0.58 : 0.34;
        cruise_downshift_rpm = gear == 6 ? 1325 : 1650;
        cruise_downshift_thr = gear == 6 ? 0.86 : 0.56;
        downshift_rpm = shift_intent_dir == -2 ? kickdown_downshift_rpm : (shift_intent_dir == -1 ? soft_downshift_rpm : (shift_intent_dir > 0 ? cruise_downshift_rpm : base_downshift_rpm));
        downshift_thr = shift_intent_dir == -2 ? kickdown_downshift_thr : (shift_intent_dir == -1 ? soft_downshift_thr : (shift_intent_dir > 0 ? cruise_downshift_thr : base_downshift_thr));
        target_trans_mode == 0 ? (
          downshift_rpm -= 140;
          downshift_thr += 0.06;
        ) : target_trans_mode == 1 ? (
          downshift_rpm += 320;
          downshift_thr -= 0.08;
        );
        downshift_speed_gate = gear == 6 ? 84.0 : gear == 5 ? 66.0 : gear == 4 ? 48.0 : gear == 3 ? 32.0 : 18.0;
        target_trans_mode == 0 ? (
          downshift_speed_gate -= 4.0;
        ) : target_trans_mode == 1 ? (
          downshift_speed_gate += 8.0;
        );
        // Kickdown should remain responsive even if speed is above nominal gate.
        downshift_speed_ok = shift_intent_dir == -2 ? 1 : (auto_speed_kmh <= downshift_speed_gate);
        downshift_thr = min(max(downshift_thr, 0.0), 1.0);
        next_ratio_down = get_gear_ratio(gear - 1);
        cur_ratio_down = get_gear_ratio(gear);
        predicted_downshift_rpm = (cur_rpm / max(cur_ratio_down, 0.01)) * next_ratio_down;
        downshift_rpm_guard = shift_intent_dir == -2 ? (target_rpm + 900) : (shift_intent_dir == -1 ? (target_rpm + 180) : (target_rpm + 420));
        cur_rpm < downshift_rpm && eff_throttle > downshift_thr && downshift_speed_ok && gear > 1 && predicted_downshift_rpm <= downshift_rpm_guard ? (
          target_gear = gear - 1;
          shift_timer = 0.3; // 300ms downshift duration
          shift_cooldown_next = gear == 6 ? (0.95 + (1.0 - eff_throttle) * 1.40) : (0.50 + (1.0 - eff_throttle) * 1.10);
          shift_blip_hold = shift_intent_dir == -2 ? (0.60 + target_throttle * 0.18) : (shift_intent_dir == -1 ? 0.06 : 0.16);
          mech_lpf += 2.0; 
          shift_jolt_pulse_env = max(shift_jolt_pulse_env, 1.10 + eff_throttle * 0.30);
          shift_jolt_hit2_pending = 1;
          shift_jolt_hit2_manual = 0;
          shift_jolt_hit2_cnt = max(1, (srate * (0.058 - eff_throttle * 0.010)) | 0);
          shift_jolt_hit2_amt = max(shift_jolt_hit2_amt, 0.74 + eff_throttle * 0.16);
          shift_scrape_env = max(shift_scrape_env, 1.10 + eff_throttle * 0.30);
          shift_scrape_burst = max(shift_scrape_burst, 12 + (eff_throttle * 7)|0);
        );
      );
    );

    cur_rpm = max(500, min(cur_rpm, limiter_rpm + 200)); // Hard guard limits
  );
);

// Decrement cold-start idle timer (drives the flare-to-normal RPM blend above)
post_start_idle_timer > 0 ? post_start_idle_timer -= (samplesblock / srate);

// Post-start RPM flare: abs(sin) wave burst, then fades cleanly to idle (mode-independent)
engine_state == 2 && post_start_idle_timer > 0 ? (
  _pn = 1.0 - post_start_idle_timer / max(0.001, post_start_idle_dur); // 0→1 over timer
  _fade = max(0.0, 1.0 - _pn * 1.12); // linear fade → reaches 0 just before timer expires
  _wave = abs(sin(_pn * pi * post_start_nrevs)) * _fade; // 1-3 rev bumps, each fading
  _flare_tgt = 800.0 + _wave * (350.0 + target_size * 1150.0); // 800..1150 small → 800..2300 large
  _flare_coeff = 1.0 - exp(-(samplesblock / srate) / 0.16); // 160ms TC: follows profile closely
  cur_rpm += (_flare_tgt - cur_rpm) * _flare_coeff;
);

// Shut off sequence
engine_state == 0 ? (
  // Speed-dependent coast-down so STOP does not kill motion instantly
  stop_speed = min(max(max(speed_display_norm, coast_speed_norm), 0.0), 1.0);
  stop_decay = 0.982 + stop_speed * 0.016;
  cur_rpm *= stop_decay;
  cur_rpm < 10.0 ? cur_rpm = 0.0;
);

// 4-stroke cycle = 2 revolutions = frequency of / 120
cycle_freq = cur_rpm / 120.0; 
phase_inc = cycle_freq / srate;

cur_pipe = smooth_param(pipe_samps, cur_pipe, 20);

@sample
// Pink noise core (Paul Kellett Cascade)
white = rand_noise();
pn_b0 = 0.99886 * pn_b0 + white * 0.0555179;
pn_b1 = 0.99332 * pn_b1 + white * 0.0750759;
pn_b2 = 0.96900 * pn_b2 + white * 0.1538520;
pn_b3 = 0.86650 * pn_b3 + white * 0.3104856;
pn_b4 = 0.55000 * pn_b4 + white * 0.5329522;
pn_b5 = -0.7616 * pn_b5 - white * 0.0168980;
pink_noise = pn_b0 + pn_b1 + pn_b2 + pn_b3 + pn_b4 + pn_b5 + pn_b6 + white * 0.5362;
pn_b6 = white * 0.115926;
pink_noise *= 0.05; // Base leveling
pn_lpf += (pink_noise - pn_lpf) * 0.15; // Lowpass to avoid electrical arc sizzle
pink_noise = pn_lpf; // Use darkened noise for combustion

// 1. Advance Master Phase (representing 2 crank revolutions)
phase_acc += phase_inc;
phase_acc >= 1.0 ? phase_acc -= 1.0;

// 2. Iterate Cylinders
sum_pulse = 0; sum_bangs = 0;
rough_fact = (target_roughness + cold_fact * 0.20) * (1.0 - cur_throttle * 0.8) * 0.5;

i = 0;
loop(target_cylinders,
  // Cylinder local phase
  c_phase = phase_acc + active_offsets[i];
  c_phase >= 1.0 ? c_phase -= 1.0;
  
  // Combustion noise shaping
  cyl_env[i] *= 0.995; // longer envelope (~10-20ms) to sound like a "chuff" instead of a "spark"
  
  // 4-Stroke Pulse (opening 0..0.25 of full 720 cycle)
  c_pulse = 0;
  // If engine is off, stop sparking logic but let it naturally decelerate to 0
  engine_state > 0 ? (
    c_phase < 0.25 ? (
      // Check leading edge trigger
      last_phase[i] >= 0.25 ? (
        
        // Rev Limiter (Fuel Cut) -> prevent firing gracefully (no harsh audio clipping!)
        cur_rpm > limiter_rpm && rand(1) > 0.2 ? (
          cyl_env[i] = 0.0; 
          amp_rnd[i] = 0.0; // Mute this specific explosion
          
          // Anti-Lag / Limiter Bangs
          target_als > 0.01 && rand(1.0) < (0.2 + target_als * 0.6) ? (
            cyl_crackle[i] = 1.0 + target_als; // Huge ALS explosion
          );
        ) : (
          cyl_env[i] = 1.0;
          amp_rnd[i] = 1.0 - abs(rand_noise() * rough_fact); // Assign per-cycle roughness

          // Unified micro-backfire map: mode + kickdown + temperature + RPM + load.
          // Works continuously, not only from crackle_burst.
          rpm_fire = min(max((cur_rpm - (base_idle_rpm + 900.0)) / 4200.0, 0.0), 1.0);
          load_fire = min(max(cur_throttle, 0.0), 1.0);
          decel_fire = min(max((-throttle_delta - 0.02) / 0.25, 0.0), 1.0);
          mode_fire = target_trans_mode == 1 ? 1.25 : 1.0;        // S mode hotter
          kick_fire = shift_intent_dir == -2 ? 1.35 : 1.0;         // kickdown burstier
          temp_fire = 0.65 + thermal_norm * 0.70;                   // hotter engine crackles more
          micro_fire_prob = target_crackle * (0.004 + rpm_fire * 0.020 + load_fire * 0.010 + decel_fire * 0.018);
          micro_fire_prob *= mode_fire * kick_fire * temp_fire;
          micro_fire_prob = min(max(micro_fire_prob, 0.0), 0.45);
          rand(1.0) < micro_fire_prob ? (
            micro_fire_amt = 0.22 + rpm_fire * 0.30 + load_fire * 0.16 + decel_fire * 0.20 + target_als * 0.20;
            cyl_crackle[i] = max(cyl_crackle[i], micro_fire_amt);
          );
          
          // Deceleration Backfire / Crackle Trigger
          crackle_burst > 0.1 ? (
            cr_prob = target_crackle * 0.9; 
            rand(1.0) < cr_prob ? cyl_crackle[i] = 1.0;
            crackle_burst *= 0.8; // Consume burst
          );
        );
      );
      
      // Phase Asymmetry / Morphing
      p = c_phase * 4.0; // Normalized mapped phase (0.0 to 1.0)
      
      // Core Character (target_character = -1.0 to 1.0)
      // > 0 : Fast Attack, Slow Decay (Rasp, 2-stroke-like)
      // < 0 : Slow Attack, Fast Decay (Thump, muffled)
      skew = target_character; 
      p_skew = pow(p, exp(-skew * 1.5)); 
      mapped = p_skew * pi;
      
      // Metallic Resonance / Sub-harmonic generated by sharp pulse timing
      res = 1.0;
      skew > 0 ? (
        // Add subtle harmonic rippling to the tail of the pulse
        res = 1.0 + (sin(p_skew * pi * 4.0) * skew * 0.15);
      );
      
      // limit HF clicks by bounding sharpness
      sharpness = max(1.0, 1.5 + (cur_throttle * 2.0)); 
      
      // Extra thickness if Thump (<0), extra bite if Rasp (>0)
      sharpness *= exp(skew * 0.3); // Skew > 0 sharpens further, < 0 dulls it

      // Compensate amplitude loss from high sharpness (pulse gets thinner, so we boost it)
      base_pulse = pow(sin(mapped), sharpness) * sqrt(sharpness) * res;
      
      c_pulse = base_pulse * amp_rnd[i];
    );
  );
  last_phase[i] = c_phase;
  
  // Dramatically reduced combustion noise to let the bass rumble shine
  c_noise = pink_noise * cyl_env[i] * (0.1 + cur_throttle * 0.4) * amp_rnd[i];
  
  // Snap pops from exhaust backfire (Crackle + ALS Bangs)
  // ALS + resonance controls stretch decay for heavier cannon-like tails
  als_decay = 0.88 + (target_als * 0.08) + (target_backfire_res * 0.032);
  als_decay = min(max(als_decay, 0.86), 0.995);
  cyl_crackle[i] *= als_decay; 
  
  // High-frequency tear + low-frequency body + resonant pipe ring, then soft-clipped.
  bang_env = cyl_crackle[i];
  c_backfire_hi = rand_noise() * bang_env * target_crackle * (0.55 + target_backfire_res * 0.20);
  c_backfire_hi += (pink_noise * 2.0) * bang_env * target_als * (2.6 + target_backfire_res * 0.70);

  bang_body_rate = 42.0 + target_backfire_body * 44.0 + target_als * 16.0;
  bang_body_phase += bang_body_rate / srate;
  bang_body_phase >= 1.0 ? bang_body_phase -= 1.0;
  bang_body = sin(bang_body_phase * pi2) * bang_env;
  bang_body_lp += (bang_body - bang_body_lp) * (0.020 + target_backfire_body * 0.018);
  c_backfire_body = bang_body_lp * (1.2 + target_als * 2.2 + target_backfire_body * 3.8);

  bang_res_src = (rand_noise() * 0.35 + pink_noise * 0.65) * bang_env;
  bang_res_lp1 += (bang_res_src - bang_res_lp1) * (0.15 + target_backfire_res * 0.11);
  bang_res_lp2 += (bang_res_lp1 - bang_res_lp2) * (0.030 + target_backfire_res * 0.020);
  c_backfire_res = (bang_res_lp1 - bang_res_lp2) * (0.55 + target_backfire_res * 2.10);

  c_backfire_pre = c_backfire_hi + c_backfire_body + c_backfire_res;
  c_backfire_pre *= (1.0 + target_als * 0.75 + target_backfire_body * 0.40);
  c_backfire = sign(c_backfire_pre) * (1.0 - exp(-abs(c_backfire_pre)));
  c_backfire *= (0.85 + bang_env * 0.65);
  
  // Massive boost to the low-end pulse vs noises
  sum_pulse += (c_pulse * 4.0) + c_noise;
  sum_bangs += c_backfire;
  
  i += 1;
);

// Level out based on cylinder count & engine size
// Use a softer attenuation curve so 8 cylinders don't lose all their punch
engine_out = (sum_pulse / (1.0 + target_cylinders * 0.15)) * (0.5 + cur_throttle * 0.5);
engine_out *= (0.5 + target_size * 1.0);

// CRITICAL: We MUST remove massive DC buildup *before* saturation!
// Otherwise 8 overlapping positive pulses squash the signal into the threshold ceiling, killing the roar.
eng_dc_in = engine_out;
engine_out = eng_dc_in - eng_prev_in + 0.995 * eng_prev_out;

// Prevent explosions
engine_out = min(max(engine_out, -50.0), 50.0); 

eng_prev_in = eng_dc_in;
eng_prev_out = engine_out;

// 4. Exhaust Waveguide (Delay & Feedback)
// Saturate slightly before hitting the pipe to generate gritty mid-range harmonics ("Roar")
// Повертаємо трохи динаміки V8 - менше розгону до сатуратора
ac_makeup = 1.0 + (target_cylinders - 1.0) * 0.35;
engine_out *= ac_makeup * 1.8;
engine_out = sign(engine_out) * (1.0 - exp(-abs(engine_out)));

// Simple Circular Buffer interpolating Delay
cur_pipe = min(max(cur_pipe, 1), exhaust_delay_len - 2);
exhaust_read_pos = exhaust_write_pos - cur_pipe;
exhaust_read_pos < 0 ? exhaust_read_pos += exhaust_delay_len;

rp_int = floor(exhaust_read_pos);
rp_frac = exhaust_read_pos - rp_int;
rp_next = (rp_int + 1) >= exhaust_delay_len ? 0 : rp_int + 1;
delayed = exhaust_buf[rp_int] * (1.0 - rp_frac) + exhaust_buf[rp_next] * rp_frac;

// LPF in delay line to damp high frequencies (waveguide friction)
delayed_lpf = delayed_lpf * exhaust_damp + delayed * (1.0 - exhaust_damp);

// Feed the pipe
exhaust_in = engine_out + (delayed_lpf * exhaust_fb);
// Absolute limit to prevent waveguide feedback blowing into Infinity / NaN
exhaust_in > 10.0 ? exhaust_in = 10.0;
exhaust_in < -10.0 ? exhaust_in = -10.0;
exhaust_buf[exhaust_write_pos] = exhaust_in;

exhaust_write_pos += 1;
exhaust_write_pos >= exhaust_delay_len ? exhaust_write_pos = 0;

// 5. Processing chain (Muffler)
core_out = engine_out;
mono_out = muffler_filter.biquad_process(exhaust_in * 1.5);

// Additional post-muffler damping to avoid synthetic high "lift" on acceleration
rpm_norm = min(cur_rpm / max(limiter_rpm, 1.0), 1.0);
muff_post_fc = muffler_freq * (1.0 - rpm_norm * (0.18 + (1.0 - target_muffler) * 0.20));
muff_post_fc = max(220.0, min(muff_post_fc, 5200.0));
muff_post_coeff = 1.0 - exp(-2.0 * pi * muff_post_fc / srate);
exhaust_post_lpf += (mono_out - exhaust_post_lpf) * muff_post_coeff;
mono_out = exhaust_post_lpf;

// Shift impact and scrape: body jolt + gearbox grind during shift transitions
shift_jolt_pulse_env *= 0.9986;
shift_scrape_env *= 0.99988;

// Second delayed jolt hit for manual gearbox-like "ta-DA" feel
shift_jolt_hit2_pending ? (
  shift_jolt_hit2_cnt -= 1;
  shift_jolt_hit2_cnt <= 0 ? (
    jolt_hit2 = shift_jolt_hit2_amt;
    shift_jolt_hit2_manual ? jolt_hit2 *= 1.08;
    shift_jolt_pulse_env = max(shift_jolt_pulse_env, jolt_hit2);
    shift_jolt_hit2_pending = 0;
    shift_jolt_hit2_manual = 0;
    shift_jolt_hit2_amt = 0.0;
  );
);

// Kick-like jolt: low-mid sine hit with natural pitch drop as envelope decays
shift_jolt_freq = 42.0 + shift_jolt_pulse_env * 34.0 + cur_throttle * 8.0;
shift_jolt_phase += shift_jolt_freq / srate;
shift_jolt_phase >= 1.0 ? shift_jolt_phase -= 1.0;
shift_jolt_raw = sin(shift_jolt_phase * pi2) * shift_jolt_pulse_env * (1.00 + cur_throttle * 0.40);
shift_jolt_raw += sin(shift_jolt_phase * pi2 * 1.45) * shift_jolt_pulse_env * 0.03;
shift_jolt_raw += pink_noise * shift_jolt_pulse_env * 0.0025;

// Build thump body: low-mid + sub tail
shift_jolt_body_lp += (shift_jolt_raw - shift_jolt_body_lp) * 0.040;
shift_jolt_sub_lp += (shift_jolt_body_lp - shift_jolt_sub_lp) * 0.012;
shift_jolt = shift_jolt_body_lp * 1.2 + shift_jolt_sub_lp * 1.6;

// Shift scrape tuned lower: low-mid metallic grind instead of high crack
shift_scrape_src = rand_noise() * 0.25 + pink_noise * 0.75;
shift_scrape_lp += (shift_scrape_src - shift_scrape_lp) * (0.020 + cur_throttle * 0.014);
shift_scrape_lp2 += (shift_scrape_lp - shift_scrape_lp2) * 0.006;
shift_scrape_band = (shift_scrape_lp - shift_scrape_lp2) + shift_scrape_lp2 * 0.20;
shift_scrape_phase += (22.0 + shift_scrape_env * 48.0 + cur_throttle * 12.0) / srate;
shift_scrape_phase >= 1.0 ? shift_scrape_phase -= 1.0;
shift_scrape_tick *= 0.9982;
shift_scrape_tick_cnt -= 1;
shift_scrape_tick_cnt <= 0 && shift_scrape_burst > 0 ? (
  shift_scrape_tick = 1.0;
  shift_scrape_burst -= 1;
  // Longer ratchet cadence so scrape reads as a sequence, not a single click
  shift_scrape_tick_cnt = max(1, (srate * (0.028 + (1.0 - cur_throttle) * 0.034)) | 0);
);
// Mixed mode: keep tick attack but add low metallic tail for sustained "krrrust"
shift_scrape_tick_part = shift_scrape_band * shift_scrape_env * (1.00 + target_drive * 0.35) * (shift_scrape_tick * 1.90);
shift_scrape_tail = shift_scrape_band * shift_scrape_env * (0.22 + cur_throttle * 0.08);
shift_scrape = shift_scrape_tick_part + shift_scrape_tail;

// 5b. Overlay Mechanical, Turbo, and Transmission

// MECHANICAL SPLIT v2: FM / Harmonic / RM+BP organic layers (Phase 1 rev2)
rpm_norm_mech = min(max((cur_rpm - base_idle_rpm) / max(limiter_rpm - base_idle_rpm, 1.0), 0.0), 1.0);
mech_master = target_mech;
mech_out = 0.0;
mech_engine_tex = 0.0;

engine_state > 0 && mech_master > 0.001 ? (

  // ─── VALVE TRAIN ─────────────────────────────────────────────────
  // FM-синтез: металічний тіктак з рінгінгом. Гострий гейт, нуль шуму.
  // Engine Size: великий → нижчий pitch, повільніший decay.
  valve_pitch_base = 2900.0 - target_size * 1400.0;        // 2900Hz (small) → 1500Hz (large)
  valve_decay_rate = exp(-1.0 / (srate * (0.005 + target_size * 0.014)));
  valve_hz = max(20.0, cycle_freq * target_cylinders * 2.0);
  mech_valve_period = max(6, (srate / valve_hz) | 0);
  mech_valve_cnt += 1;
  mech_valve_cnt >= mech_valve_period ? (
    mech_valve_cnt = 0;
    mech_valve_env = 1.0;
    mech_valve_freq = valve_pitch_base * (0.91 + rpm_norm_mech * 0.14 +
                      (rand(1.0) - 0.5) * (0.05 + target_size * 0.10));
    valve_fm_phase = 0.0;   // скид FM фази → гострий металічний transient
  );
  mech_valve_env *= valve_decay_rate;
  valve_fm_mod = sin(valve_fm_phase * pi2) * (0.70 - target_size * 0.28);
  valve_fm_phase += (mech_valve_freq * 2.75) / srate;
  valve_fm_phase >= 1.0 ? valve_fm_phase -= 1.0;
  mech_valve_phase += mech_valve_freq / srate;
  mech_valve_phase >= 1.0 ? mech_valve_phase -= 1.0;
  valve_tone = sin(mech_valve_phase * pi2 + valve_fm_mod * 1.40);
  mech_valve_lp += (valve_tone - mech_valve_lp) * 0.30;
  valve_high = valve_tone - mech_valve_lp;
  valve_warm = mech_valve_lp * 0.78 + valve_high * 0.22;
  mech_valve_click = valve_warm * mech_valve_env * (0.56 + target_size * 0.18);

  // ─── BELT / PULLEY ───────────────────────────────────────────────
  // 3 harmonic tones + AM wobble. Без noise — чистий тональний вір.
  // Engine Size: великий → нижче, жорсткіший harmonic stack.
  belt_base_hz  = 60.0 + cur_rpm * (0.070 + target_size * 0.016);
  belt_h2_ratio = 2.01 + target_size * 0.04;
  belt_h3_ratio = 3.02 - target_size * 0.05;
  belt_am_rate  = 7.0  + rpm_norm_mech * 9.0 + target_size * 4.0;  // 7..20 Hz AM
  mech_belt_phase  += belt_base_hz / srate;
  mech_belt_phase  >= 1.0 ? mech_belt_phase  -= 1.0;
  belt_harm2_phase += (belt_base_hz * belt_h2_ratio) / srate;
  belt_harm2_phase >= 1.0 ? belt_harm2_phase -= 1.0;
  belt_harm3_phase += (belt_base_hz * belt_h3_ratio) / srate;
  belt_harm3_phase >= 1.0 ? belt_harm3_phase -= 1.0;
  belt_am_phase    += belt_am_rate / srate;
  belt_am_phase    >= 1.0 ? belt_am_phase    -= 1.0;
  belt_h1  = sin(mech_belt_phase  * pi2);
  belt_h2  = sin(belt_harm2_phase * pi2) * (0.45 - target_size * 0.10);
  belt_h3  = sin(belt_harm3_phase * pi2) * (0.22 + target_size * 0.08);
  belt_am  = 0.70 + sin(belt_am_phase * pi2) * 0.30;
  belt_sum = (belt_h1 + belt_h2 + belt_h3) * belt_am;
  mech_belt_lp += (belt_sum - mech_belt_lp) * (0.025 + rpm_norm_mech * 0.035);
  mech_belt_whirr = mech_belt_lp * (0.35 + rpm_norm_mech * 0.80);

  // ─── CHAIN RATTLE ────────────────────────────────────────────────
  // RM-збудник (ring modulation) → RBJ bandpass → жирне органічне брязкання.
  // Engine Size: великий → нижчий резонанс, глибший гейт.
  chain_base_hz  = 160.0 + (1.0 - target_size) * 160.0;  // 160..320 Hz trigger
  chain_res_hz   = 220.0 - target_size * 90.0;            // BP center: 220..130 Hz
  chain_qf       = 2.5   + target_size * 3.5;             // Q 2.5..6.0
  chain_decay_rate = exp(-1.0 / (srate * (0.020 + target_size * 0.045)));
  chain_idle_boost = 0.45 + (1.0 - rpm_norm_mech) * 1.10;
  mech_chain_cnt -= 1;
  mech_chain_cnt <= 0 ? (
    mech_chain_env = 1.0;
    chain_interval_ms = 14.0 - rpm_norm_mech * 5.0 +
                        (rand(1.0) - 0.5) * (5.0 + target_size * 8.0);
    mech_chain_cnt = max(1, (srate * max(chain_interval_ms, 2.0) * 0.001) | 0);
    mech_chain_freq = chain_base_hz * (0.85 + (rand(1.0) - 0.5) * (0.12 + target_size * 0.14));
    chain_am_phase = 0.0;   // скид AM → різкий початок ланки
  );
  mech_chain_env *= chain_decay_rate;
  mech_chain_phase += mech_chain_freq / srate;
  mech_chain_phase >= 1.0 ? mech_chain_phase -= 1.0;
  chain_am_phase  += (mech_chain_freq * 0.52) / srate;
  chain_am_phase  >= 1.0 ? chain_am_phase  -= 1.0;
  // Ring modulation: carrier × (AM envelope half-wave) = металічний клацок без DC
  chain_excite    = sin(mech_chain_phase * pi2) * (sin(chain_am_phase * pi2) * 0.50 + 0.50);
  chain_excite_in = chain_excite * mech_chain_env;
  // RBJ Bandpass (Direct Form I, нормалізований)
  chain_w0      = 2.0 * pi * min(chain_res_hz, srate * 0.45) / srate;
  chain_alpha_c = sin(chain_w0) / (2.0 * chain_qf);
  chain_inv_a0c = 1.0 / (1.0 + chain_alpha_c);
  chain_a1c     = -2.0 * cos(chain_w0) * chain_inv_a0c;
  chain_a2c     = (1.0 - chain_alpha_c) * chain_inv_a0c;
  chain_b0c     = chain_alpha_c * chain_inv_a0c;
  chain_bp_out  = chain_b0c * (chain_excite_in - chain_bp_x2)
                  - chain_a1c * chain_bp_y1 - chain_a2c * chain_bp_y2;
  chain_bp_x2 = chain_bp_x1; chain_bp_x1 = chain_excite_in;
  chain_bp_y2 = chain_bp_y1; chain_bp_y1 = chain_bp_out;
  mech_chain_rattle = chain_bp_out * chain_idle_boost * (0.70 + target_size * 0.55);

  // ─── MIX ─────────────────────────────────────────────────────────
  valve_layer = mech_valve_click  * target_valve * mech_master;
  belt_layer  = mech_belt_whirr   * target_belt  * mech_master;
  chain_layer = mech_chain_rattle * target_chain * mech_master;

  mech_out = valve_layer * 0.72 + belt_layer * 0.98 + chain_layer * 1.24;
  mech_engine_tex = valve_layer * 0.24 + chain_layer * 0.52;

) : (
  mech_valve_cnt = 0;
  mech_valve_env = 0.0;
  mech_valve_lp  *= 0.90;
  mech_belt_lp   *= 0.90;
  belt_harm2_phase = 0.0;
  belt_harm3_phase = 0.0;
  mech_chain_env  = 0.0;
  chain_bp_y1 *= 0.90; chain_bp_y2 *= 0.90;
  mech_engine_tex = 0.0;
  mech_out = 0.0;
);

// Turbo Whine & Blow-off Valve (BOV)
rpm_norm_turbo = min(max((cur_rpm - base_idle_rpm) / max(limiter_rpm - base_idle_rpm, 1.0), 0.0), 1.0);
// Idle floor scales with speed: at standstill floor=0 so spool fully collapses when pedal off
turbo_idle_floor = 0.08 * min(1.0, norm_speed / 0.06);
turbo_req = target_turbo * (turbo_idle_floor + cur_throttle * 0.92) * (0.18 + pow(rpm_norm_turbo, 0.85) * 0.82);
// Nonlinear spool inertia: slower at low RPM, faster at high RPM
turbo_atk_tc = 0.160 - rpm_norm_turbo * 0.120;  // 160ms -> 40ms
turbo_rel_tc = 0.260 - rpm_norm_turbo * 0.170;  // 260ms -> 90ms
turbo_spool_coeff = turbo_req > turbo_spool
  ? (1.0 - exp(-1.0 / (srate * max(turbo_atk_tc, 0.020))))
  : (1.0 - exp(-1.0 / (srate * max(turbo_rel_tc, 0.030))));
turbo_spool += (turbo_req - turbo_spool) * turbo_spool_coeff;
turbo_spool = min(max(turbo_spool, 0.0), 1.0);

// Overpump decay + short surge wobble after abrupt throttle lift
turbo_overpump_env *= exp(-1.0 / (srate * 0.220));
turbo_overpump_env = min(max(turbo_overpump_env, 0.0), 1.0);
turbo_surge_phase += (12.0 + rpm_norm_turbo * 18.0) / srate;
turbo_surge_phase >= 1.0 ? turbo_surge_phase -= 1.0;
turbo_surge = sin(turbo_surge_phase * pi2) * turbo_overpump_env;

turbo_freq = 2600 + pow(turbo_spool, 1.25) * 9300 + turbo_surge * 220;
turbo_phase += turbo_freq / srate;
turbo_phase >= 1.0 ? turbo_phase -= 1.0;
// Spool-driven whine with hard zero at Turbo Amount=0 to prevent idle ringing on Air bus
target_turbo <= 0.001 ? (
  turbo_whine_amp = 0.0;
  turbo_whine = 0.0;
) : (
  turbo_whine_amp = (0.006 + turbo_spool * 0.052) * target_turbo * (1.0 - turbo_overpump_env * 0.35);
  turbo_whine = sin(turbo_phase * pi2 + pink_noise * (0.08 + turbo_spool * 0.12)) * turbo_whine_amp;
);

bov_burst > 0.01 ? ( 
  bov_goal = bov_burst; 
  bov_burst = 0; 
  // Randomize the High-Pass filter frequency for each blow-off (darker now)
  bov_cut_goal = 0.15 + rand(0.3); // 0.15 to 0.45
); 
bov_cut_goal == 0.0 ? bov_cut_goal = 0.3;

// Very steady, long decay for the "Pshhhh" tail (~300ms)
bov_goal *= 0.9996; 
// Overpump feeds a short pshhh tail on abrupt pedal release
bov_goal += turbo_overpump_env * (0.0009 + target_turbo * 0.0016);
// Attack smoother: 0.01 prevents the instant "click" while keeping it explosive
bov_env += (bov_goal - bov_env) * 0.015;

// Smooth filter target so it doesn't pop when triggered
bov_cut += (bov_cut_goal - bov_cut) * 0.01;
bov_cut = max(0.05, min(bov_cut, 0.8));

// Layer crisp White Noise (rand_noise) on top of thick Pink Noise for maximum 'Pshhhh'
// Reduced white noise, increased pink noise to blend better with the engine body
bov_noise = (rand_noise() * 0.5) + (pink_noise * 1.5); 
bov_lpf += (bov_noise - bov_lpf) * bov_cut;
// High-pass the noise to isolate the sharp hiss
turbo_bov = (bov_noise - bov_lpf) * bov_env * 0.45;

// Intake / Induction Noise
// Mid-range roar reacting to throttle opening + current RPM
intake_raw = pink_noise * 3.5; // Louder base
intake_lpf += (intake_raw - intake_lpf) * 0.15; // lowpass for "whooosh"
intake_hpf = intake_raw - intake_lpf; // bandpassed
// Speed-coupled envelope: at standstill with no throttle, intake fades to zero
intake_motion = max(cur_throttle, norm_speed * 0.28);
intake_env += (intake_motion - intake_env) * 0.05; // smoothing envelope
// Boosted the raw output level significantly
intake_out = intake_hpf * target_intake * intake_env * (0.1 + cur_rpm / 9000.0) * 0.8;

// Transmission / Reverse Whine + Reverse Beep
gear > 0 ? (
  whine_freq = cur_rpm * gear_ratio * 0.45;
  whine_phase += whine_freq / srate;
  whine_phase >= 1.0 ? whine_phase -= 1.0;
  // Add very subtle noise FM to whine, rather than mech_out which has huge transients
  whine_out = sin(whine_phase * pi2 + pink_noise * 0.1) * target_whine * (cur_rpm / 9000.0) * 0.05;
  rev_beep_out = 0.0;
) : gear < 0 ? (
  rev_whine_freq = 230.0 + cur_rpm * 0.20;
  rev_whine_phase += rev_whine_freq / srate;
  rev_whine_phase >= 1.0 ? rev_whine_phase -= 1.0;
  rev_whine = (sin(rev_whine_phase * pi2) + sin(rev_whine_phase * pi2 * 2.03) * 0.30)
              * target_whine * (0.020 + cur_rpm / 9000.0 * 0.030);
  whine_out = rev_whine;

  rev_beep_timer -= 1;
  rev_beep_timer <= 0 ? (
    rev_beep_gate = 1 - rev_beep_gate;
    rev_beep_timer = rev_beep_gate ? max(1, (srate * 0.17) | 0) : max(1, (srate * 0.48) | 0);
  );
  rev_beep_tgt = rev_beep_gate ? 1.0 : 0.0;
  rev_beep_env += (rev_beep_tgt - rev_beep_env) * (rev_beep_tgt > rev_beep_env ? 0.018 : 0.010);
  // Fixed tone at slider60 pitch (no LFO, pure single frequency)
  rev_beep_freq = rev_beep_pitch;
  rev_beep_phase += rev_beep_freq / srate;
  rev_beep_phase >= 1.0 ? rev_beep_phase -= 1.0;
  rev_beep_tone = sin(rev_beep_phase * pi2) + sin(rev_beep_phase * pi2 * 2.02) * 0.20;
  rev_beep_out = rev_beep_tone * rev_beep_env * 0.050 * rev_beep_level;
) : (
  whine_out = 0;
  rev_beep_gate = 0;
  rev_beep_timer = 0;
  rev_beep_env *= 0.85;
  rev_beep_out = 0.0;
);

// ===== Interior/Cabin: Indicator Relay Clicks and Ambiance =====
// Indicator modes: 0=Off, 1=Left, 2=Right, 3=Hazard.
// Generates discrete relay click bursts on each blink edge (no continuous merged tone).
target_ind_mode > 0 ? (
  ind_click_timer -= 1;
  ind_click_timer <= 0 ? (
    ind_flash = 1 - ind_flash;
    ind_click_env = 1.0;
    target_ind_mode == 3 ? (
      ind_click_timer = ind_flash ? max(1, (srate * 0.42) | 0) : max(1, (srate * 0.42) | 0);
    ) : (
      ind_click_timer = ind_flash ? max(1, (srate * 0.50) | 0) : max(1, (srate * 0.50) | 0);
    );
  );
  ind_edge_on = ind_flash > 0;

  target_ind_type == 0 ? (
    ind_f1 = ind_edge_on ? (target_ind_mode == 2 ? 1980.0 : 1760.0) : (target_ind_mode == 2 ? 1450.0 : 1310.0);
    ind_f2 = ind_edge_on ? (target_ind_mode == 2 ? 1210.0 : 1080.0) : (target_ind_mode == 2 ? 940.0 : 850.0);
    ind_noise_mix = ind_edge_on ? 0.58 : 0.72;
    ind_decay = ind_edge_on ? 0.99930 : 0.99905;
    ind_gain = ind_edge_on ? 0.172 : 0.150;
  ) : target_ind_type == 1 ? (
    ind_f1 = ind_edge_on ? (target_ind_mode == 2 ? 1440.0 : 1290.0) : (target_ind_mode == 2 ? 1100.0 : 980.0);
    ind_f2 = ind_edge_on ? (target_ind_mode == 2 ? 900.0 : 800.0) : (target_ind_mode == 2 ? 710.0 : 640.0);
    ind_noise_mix = ind_edge_on ? 0.40 : 0.52;
    ind_decay = ind_edge_on ? 0.99950 : 0.99922;
    ind_gain = ind_edge_on ? 0.152 : 0.132;
  ) : (
    ind_f1 = ind_edge_on ? (target_ind_mode == 2 ? 2480.0 : 2260.0) : (target_ind_mode == 2 ? 2020.0 : 1840.0);
    ind_f2 = ind_edge_on ? (target_ind_mode == 2 ? 1580.0 : 1460.0) : (target_ind_mode == 2 ? 1290.0 : 1180.0);
    ind_noise_mix = ind_edge_on ? 0.67 : 0.78;
    ind_decay = ind_edge_on ? 0.99912 : 0.99892;
    ind_gain = ind_edge_on ? 0.185 : 0.162;
  );

  ind_phase += ind_f1 / srate;
  ind_phase >= 1.0 ? ind_phase -= 1.0;
  ind_lfo += ind_f2 / srate;
  ind_lfo >= 1.0 ? ind_lfo -= 1.0;

  ind_click_tone = sin(ind_phase * pi2) * 0.62 + sin(ind_lfo * pi2) * 0.38;
  ind_body_lp += (ind_click_tone - ind_body_lp) * 0.14;
  ind_click_sig = pink_noise * ind_noise_mix + ind_click_tone * (1.0 - ind_noise_mix);
  ind_click_sig = ind_click_sig * 0.72 + ind_body_lp * 0.55;
  ind_click_out = ind_click_sig * ind_click_env * target_ind_level * ind_gain;
  ind_click_env *= ind_decay;
  ind_click_env < 0.0007 ? ind_click_env = 0.0;
) : (
  ind_click_out = 0.0;
  ind_click_timer = 0;
  ind_flash = 0;
  ind_click_env *= 0.96;
  ind_body_lp *= 0.96;
);

// Cabin ambiance: subtle low-level filtered noise background
cabin_amb_phase += (120.0 + pink_noise * 20.0) / srate;
cabin_amb_phase >= 1.0 ? cabin_amb_phase -= 1.0;
cabin_amb_lfo_val = sin(cabin_amb_phase * pi2) * 0.22 + pink_noise * 0.16 + rand_noise() * 0.06;
cabin_amb_lp += (cabin_amb_lfo_val - cabin_amb_lp) * 0.050;
cabin_amb_air += (cabin_amb_lfo_val - cabin_amb_air) * 0.22;
cabin_amb_out = (cabin_amb_lp * 0.72 + (cabin_amb_lfo_val - cabin_amb_air) * 0.28) * target_cabin_amb * 0.110;
// Important: all coefficients below are time-constant based (srate-correct), not raw per-sample constants.
speed_scale_ref = limiter_rpm / max(get_gear_ratio(6), 0.01);
speed_scale_ref = max(speed_scale_ref, 9000.0);
// Brake coupling into speed mechanics: pressed brake should actively kill wheel inertia.
brake_speed_ctl = max(cur_brake, target_brake);
launch_intent = max(target_throttle, cur_throttle);
brake_released = brake_speed_ctl < 0.08;
// Do not let idle RPM (around 800) keep car speed alive.
idle_speed_deadband = 120.0 + brake_speed_ctl * 180.0;
speed_drive_rpm = max(cur_rpm - base_idle_rpm - idle_speed_deadband, 0.0);
// Small launch assist so speedometer wakes up when gas is applied from standstill.
speed_drive_rpm += launch_intent * 220.0;
speed_factor = gear > 0 ? (speed_drive_rpm / max(gear_ratio, 0.01))
  : gear < 0 ? min(speed_drive_rpm / max(abs(gear_ratio), 0.01), speed_scale_ref * 0.13)
  : -1.0;
speed_wheel_prev = speed_wheel_est;
speed_couple = max(0.02, 1.0 - brake_speed_ctl * 0.96);
// Stop-hold release: move only after deliberate throttle, neutral, or ignition off.
speed_stop_hold && (
  (launch_intent > 0.025 && brake_released && gear != 0 && target_ignition) ||
  gear == 0 || target_ignition == 0
) ? (
  speed_stop_hold = 0;
  // Gentle wake-up from standstill so speedometer оживає without jump.
  speed_factor > 0 ? speed_wheel_est = max(speed_wheel_est, speed_factor * 0.08);
);
speed_stop_hold ? speed_couple = 0.0;
// Under real braking with closed throttle, fully decouple speed estimator from RPM pull.
brake_speed_ctl > 0.10 && launch_intent < 0.18 ? speed_couple = 0.0;
shift_timer > 0 ? (
  // During shift preserve wheel inertia, very slow loss (~2.8%/sec)
  wheel_shift_coast = exp(-1.0 / (srate * 35.0));
  speed_wheel_est *= wheel_shift_coast;
  speed_factor > 0 && speed_stop_hold == 0 ? speed_wheel_est = max(speed_wheel_est, speed_factor * speed_couple);
) : speed_factor > 0 && speed_stop_hold == 0 ? (
  // Normal driving: gently converge to measured wheel speed
  wheel_sync_coeff = 1.0 - exp(-1.0 / (srate * 0.22));
  speed_wheel_est += (speed_factor - speed_wheel_est) * wheel_sync_coeff * speed_couple;
  // While braking, do not let RPM back-drive wheel speed estimate upward.
  brake_speed_ctl > 0.12 && cur_throttle < 0.18 ? speed_wheel_est = min(speed_wheel_est, speed_factor);
) : (
  // Neutral / no valid ratio: let speed decay by inertia, don't collapse instantly
  wheel_neutral_coast = exp(-1.0 / (srate * 18.0));
  speed_wheel_est *= wheel_neutral_coast;
);
brake_speed_ctl > 0.02 ? (
  // Surface-dependent braking decel: stronger on concrete, weaker on gravel/wet.
  surf_brake_mu = surface_type == 0 ? 1.00 : surface_type == 1 ? 1.08 : surface_type == 2 ? 0.72 : 0.62;
  speed_norm_est = min(max(speed_wheel_est / speed_scale_ref, 0.0), 1.0);
  // Physical trend: decel grows with speed; add low-speed assist to avoid endless crawl.
  speed_brake_shape = 0.35 + pow(speed_norm_est, 0.72) * 0.95;
  low_speed_assist = max(0.0, (0.06 - speed_norm_est) / 0.06);
  // Return to more physical brake size: still strong enough to stop, less "arcade" clamp.
  brake_decel_rate = (brake_speed_ctl * brake_speed_ctl) * (1.35 + surf_brake_mu * 3.20 * speed_brake_shape);
  brake_decel_rate += brake_speed_ctl * low_speed_assist * (0.75 + surf_brake_mu * 0.55);
  // Extra clamp when pedal is pressed and gas is mostly closed.
  launch_intent < 0.15 ? brake_decel_rate += brake_speed_ctl * (0.35 + surf_brake_mu * 0.45);
  brake_drag = exp(-brake_decel_rate / srate);
  speed_wheel_est *= brake_drag;
);
cur_handbrake += (target_handbrake - cur_handbrake) * (1.0 - exp(-1.0 / (srate * 0.045)));
handbrake_speed_norm = min(max(speed_wheel_est / speed_scale_ref, 0.0), 1.0);
cur_handbrake > 0.02 ? (
  hb_mu = surface_type == 0 ? 1.00 : surface_type == 1 ? 1.06 : surface_type == 2 ? 0.74 : 0.66;
  hb_drag_rate = pow(cur_handbrake, 1.50) * (0.55 + hb_mu * (2.0 + handbrake_speed_norm * 4.4));
  hb_drag = exp(-hb_drag_rate / srate);
  speed_wheel_est *= hb_drag;
  cur_handbrake > 0.88 && handbrake_speed_norm < 0.014 && launch_intent < 0.10 ? speed_wheel_est = 0.0;
);
// Absolute guard: braking must never increase estimated speed.
brake_speed_ctl > 0.08 && launch_intent < 0.20 ? speed_wheel_est = min(speed_wheel_est, speed_wheel_prev);
speed_factor_est = speed_wheel_est;
speed_factor_est = min(max(speed_factor_est, 0.0), speed_scale_ref * 1.2);
speed_norm_raw = min(max(speed_factor_est / speed_scale_ref, 0.0), 1.0);
// Fast rise / slow fall with real time constants
spd_fall_tc = 1.80;
// Meter and wind should not "float" while braking to stop.
brake_speed_ctl > 0.08 && launch_intent < 0.20 ? spd_fall_tc = 0.10;
speed_stop_hold ? spd_fall_tc = 0.05;
spd_coeff = speed_norm_raw > speed_display_norm
  ? (1.0 - exp(-1.0 / (srate * 0.10)))
  : (1.0 - exp(-1.0 / (srate * spd_fall_tc)));
speed_display_norm += (speed_norm_raw - speed_display_norm) * spd_coeff;
veh_speed_norm = target_veh_speed_override > 0.0 ? target_veh_speed_override : speed_display_norm;
veh_speed_raw = target_veh_speed_override > 0.0 ? target_veh_speed_override : speed_norm_raw;
coast_coeff = target_ignition
  ? (1.0 - exp(-1.0 / (srate * 0.45)))
  : (1.0 - exp(-1.0 / (srate * 2.80)));
// While braking, inertia memory must collapse quickly (no 15-20s coast tail).
brake_speed_ctl > 0.08 && launch_intent < 0.20 ? (
  coast_coeff = 1.0 - exp(-1.0 / (srate * 0.070));
);
coast_speed_norm += (speed_norm_raw - coast_speed_norm) * coast_coeff;
brake_speed_ctl > 0.08 && launch_intent < 0.20 ? (
  // Hard cap: coast memory cannot stay above physical wheel estimate while braking.
  coast_speed_norm = min(coast_speed_norm, speed_norm_raw + 0.002);
);
coast_speed_norm = min(max(coast_speed_norm, 0.0), 1.0);

// Near-stop brake lock: if user is braking and throttle is low, snap residual motion to zero.
stop_lock_cond = brake_speed_ctl > 0.12 && speed_display_norm < 0.020 && coast_speed_norm < 0.024 && launch_intent < 0.04;
stop_lock_cond ? (
  speed_stop_hold = 1;
  speed_wheel_est = 0.0;
  speed_factor_est = 0.0;
  speed_norm_raw = 0.0;
  speed_display_norm = 0.0;
  coast_speed_norm = 0.0;
);
ign_gate_tgt = target_ignition ? 1.0 : 0.0;
env_release = 1.0 - exp(-1.0 / (srate * max(0.08, stop_release_sec)));
env_coeff = ign_gate_tgt > stop_noise_env ? 0.02 : env_release;
stop_noise_env += (ign_gate_tgt - stop_noise_env) * env_coeff;

// Traction/slip trigger: sharp throttle punch in low gears with enough RPM/load
slip_cooldown -= 1;
slip_hold -= 1;
slip_gear_weight = gear == -1 ? 0.30 : gear == 1 ? 1.00 : gear == 2 ? 0.75 : gear == 3 ? 0.42 : 0.0;
slip_thr_kick = max(0.0, throttle_delta);
slip_rpm_gate = min(max((cur_rpm - (base_idle_rpm + 700.0)) / 2600.0, 0.0), 1.0);
// Vehicle Speed Override: якщо встановлено — slip бачить незалежну швидкість (дрифт/бурнаут)
// При Auto (0) — береться speed_display_norm (від RPM/gear)
target_veh_speed_override > 0.0 ? (
  slip_speed_norm = target_veh_speed_override;
) : (
  slip_speed_norm = veh_speed_norm;
);
slip_speed_gate = min(max((slip_speed_norm - 0.025) / 0.25, 0.0), 1.0);
// При override: слабший speed gate (бо швидкість ≠ RPM — це і є дрифт)
target_veh_speed_override > 0.0 ? slip_speed_gate = max(slip_speed_gate, 0.60);
// Drift aggression now linked to brake squeal and overtone for unified character
brake_squeal_link = max(0.0, target_brake_squeal - 0.20) * 1.25;  // 0 if squeal <20%, scales 0..1+ above
brake_overtone_link = target_brake_overtone * 0.95;              // 0..0.95 range tracks brake overtone
slip_aggr = 0.75 + (target_drift_aggr * 1.65 + brake_squeal_link * 0.60) * (0.85 + brake_overtone_link * 0.15);
slip_trigger = slip_thr_kick * slip_gear_weight * (0.35 + cur_throttle * 0.65) * (0.25 + slip_rpm_gate * 0.75) * (0.35 + slip_speed_gate * 0.65) * slip_aggr;
engine_state == 2 && target_mode == 1 && slip_cooldown <= 0 && slip_trigger > 0.012 ? (
  slip_env = max(slip_env, 0.34 + slip_trigger * 5.2);
  slip_burst_env = max(slip_burst_env, 0.58 + slip_trigger * 4.4);
  slip_hold = max(1, (srate * (0.11 + target_drift_aggr * 0.20 + abs(rand_noise()) * 0.06)) | 0);
  slip_cooldown = max(1, (srate * (0.08 + abs(rand_noise()) * (0.10 + target_size * 0.08))) | 0);
);
slip_hold > 0 ? slip_env = max(slip_env, 0.20 + target_drift_aggr * 0.22);
// Drift mode (Vehicle Speed Override active): continuously sustain slip at high level
// This ensures tire squeal is present throughout the drift, not just on throttle kicks
target_veh_speed_override > 0.0 && engine_state == 2 ? (
  slip_hold = max(slip_hold, (srate * 0.06) | 0);
  slip_env = max(slip_env, 0.42 + target_drift_aggr * 0.58);
);
slip_burst_env *= 0.976;
slip_env *= (0.9966 - min(max(speed_display_norm, 0.0), 1.0) * 0.0008);

// Road / Tire Noise
// Dependent on theoretical vehicle speed (RPM / gear ratio)
road_out = 0.0;
chassis_out = 0.0;
road_override_active = target_veh_speed_override > 0.0;
(road_override_active && target_veh_speed_override > 0.002) || (gear != 0 && (engine_state > 0 || coast_speed_norm > 0.002)) ? (
  // Hold a small motion memory after STOP for natural rolling fade
  braking_hard_tail_cut = brake_speed_ctl > 0.08 && launch_intent < 0.20;
  norm_speed = road_override_active
    ? target_veh_speed_override
    : (braking_hard_tail_cut ? speed_norm_raw : max(speed_norm_raw, coast_speed_norm * stop_noise_env));
  wheel_hz = road_override_active
    ? (8.0 + norm_speed * 68.0)
    : ((cur_rpm / 60.0) / max(gear_ratio, 0.01));

  // Surface profile: Asphalt, Concrete, Gravel, Wet
  surface_type == 0 ? (
    sf_contact = 1.00; sf_tread = 1.00; sf_rumble = 1.00; sf_chassis = 1.00; sf_grain = 1.00;
  ) : surface_type == 1 ? (
    sf_contact = 1.30; sf_tread = 0.70; sf_rumble = 0.85; sf_chassis = 1.05; sf_grain = 0.80;
  ) : surface_type == 2 ? (
    sf_contact = 1.10; sf_tread = 0.55; sf_rumble = 1.55; sf_chassis = 1.35; sf_grain = 1.65;
  ) : (
    sf_contact = 0.85; sf_tread = 0.45; sf_rumble = 0.80; sf_chassis = 0.88; sf_grain = 0.65;
  );

  // 1st/2nd gear emphasis for launch presence
  low_gear_gain = gear == -1 ? (1.18 + cur_throttle * 0.08) :
                  gear == 1 ? (1.26 + cur_throttle * 0.10) :
                  gear == 2 ? (1.14 + cur_throttle * 0.06) :
                  gear == 3 ? 1.05 : 1.0;
  low_gear_texture = gear == -1 ? 1.25 : (gear == 1 ? 1.45 : gear == 2 ? 1.20 : 1.0);
  
  // Slowly varying roughness coefficient: mimics asphalt texture changes
  road_rand_cnt <= 0 ? (
    road_rand_tgt = 0.65 + abs(rand_noise()) * 0.55;
    road_rand_cnt = max(1, (srate * (0.05 + (1.0 - norm_speed) * 0.10)) | 0);
  ) : (
    road_rand_cnt -= 1;
  );
  road_rand += (road_rand_tgt - road_rand) * 0.0015;

  // Contact-patch broadband noise, shaped to band-limited tire hiss/roar
  tire_raw = rand_noise();
  // LPF cutoff shifts slightly with speed (spectral brightness), but amplitude stays flat
  road_contact_lp1 += (tire_raw - road_contact_lp1) * (0.04 + norm_speed * 0.10);
  road_contact_lp2 += (tire_raw - road_contact_lp2) * (0.008 + norm_speed * 0.02);
  tire_contact = (road_contact_lp1 - road_contact_lp2) * 0.75 * sf_contact;

  // Tread tonal components (two bands) follow wheel speed with drift
  road_tread_f1 = 16.0 + wheel_hz * 0.42 + road_rand * 8.0;
  road_tread_f2 = 30.0 + wheel_hz * 0.70 + road_rand * 12.0;
  road_tread_phase += road_tread_f1 / srate;
  road_tread_phase >= 1.0 ? road_tread_phase -= 1.0;
  road_tread2_phase += road_tread_f2 / srate;
  road_tread2_phase >= 1.0 ? road_tread2_phase -= 1.0;

  road_grain += (abs(pink_noise) - road_grain) * ((0.01 + norm_speed * 0.02) * low_gear_texture);
  tread_env = (0.35 + norm_speed * 0.85) * (0.75 + road_grain * 0.7 * sf_grain) * low_gear_texture;
  tire_tread = (
    sin(road_tread_phase * pi2) * 0.65 +
    sin(road_tread2_phase * pi2 + road_rand * 1.7) * 0.35
  ) * tread_env * sf_tread;

  // Concrete: repeating slab resonance / seam tone
  concrete_tone = (
    sin(road_tread_phase * pi2 * 3.2 + road_rand * 1.8) * 0.55 +
    sin(road_tread2_phase * pi2 * 2.0) * 0.45
  ) * (0.20 + norm_speed * 0.70);

  // Gravel: softer pebble impacts (less electric crackle)
  rand_noise() > (0.9975 - norm_speed * 0.006) ? gravel_env = min(gravel_env + 0.55, 1.0);
  gravel_env *= (0.94 - norm_speed * 0.03);
  gravel_src = rand_noise() * 0.7 + pink_noise * 0.3;
  gravel_lp += (gravel_src - gravel_lp) * (0.06 + norm_speed * 0.08);
  gravel_hit = (gravel_lp + sin(road_tread_phase * pi2 * 4.7 + road_rand * 2.3) * 0.18) * gravel_env;

  // Wet: spray hiss (broad high-band, less tonal tread)
  road_spray_lp += (tire_raw - road_spray_lp) * (0.012 + norm_speed * 0.10);
  spray_hiss = (tire_raw - road_spray_lp) * (0.30 + norm_speed * 1.25);

  // Mid/low road rumble that is not fully tonal (reduced pink-noise dominance)
  tire_rumble = pink_noise * (0.30 + sin(speed_factor * 0.0024 * pi2) * 0.35) * sf_rumble;

  // Independent chassis sub-rumble (not phase-locked to engine cycle)
  // Speed-following sub frequency with random drift so it stays organic
  road_sub_freq = 22.0 + norm_speed * 34.0 + road_rand * 7.0;
  road_sub_phase += road_sub_freq / srate;
  road_sub_phase >= 1.0 ? road_sub_phase -= 1.0;
  road_sub = sin(road_sub_phase * pi2);

  // Rough low-band body resonance
  body_raw = pink_noise * (0.35 + norm_speed * 0.45);
  road_rumble_lpf += (body_raw - road_rumble_lpf) * (0.004 + norm_speed * 0.01);
  road_sub_lpf += (road_sub - road_sub_lpf) * 0.02;
  chassis_rumble = (road_rumble_lpf * 1.8 + road_sub_lpf * (0.9 + road_rand * 0.5)) * sf_chassis;
  
  // Surface-specific blend: tire_contact toned down, texture/character layers upfront
  surface_type == 0 ? ( // Asphalt: тихий фон + виразний протектор
    road_mix = (tire_contact * 0.55) + (tire_tread * 2.0) + (tire_rumble * 1.1);
    chassis_mix = (chassis_rumble * 2.4) + (tire_tread * 0.45);
  ) : surface_type == 1 ? ( // Concrete: тональний плитний гул домінує
    road_mix = (tire_contact * 0.50) + (concrete_tone * 2.8) + (tire_rumble * 0.65);
    chassis_mix = (chassis_rumble * 2.0) + (concrete_tone * 0.60);
  ) : surface_type == 2 ? ( // Gravel: удари + фон
    road_mix = (tire_contact * 0.55) + (gravel_hit * 2.4) + (tire_rumble * 1.2);
    chassis_mix = (chassis_rumble * 2.5) + (gravel_hit * 0.45);
  ) : ( // Wet: spray hiss + мінімум тонального
    road_mix = (tire_contact * 0.45) + (spray_hiss * 2.8) + (tire_tread * 0.35) + (tire_rumble * 0.45);
    chassis_mix = (chassis_rumble * 1.9) + (spray_hiss * 0.45);
  );

  // Traction/road slip layer: tire squeal + short drivetrain body slap
  // Noise texture (friction bedding)
  slip_src = rand_noise() * 0.76 + pink_noise * 0.24;
  slip_noise_lp += (slip_src - slip_noise_lp) * (0.09 + norm_speed * 0.11 + slip_env * 0.06);
  slip_noise_hp += (slip_noise_lp - slip_noise_hp) * (0.010 + norm_speed * 0.032);
  slip_band = slip_noise_lp - slip_noise_hp;
  // Surface profile for slip (mirrors brake surface system)
  // Asphalt: тональний вереск ~680 Гц, помірний wander
  slip_surf_base   = 620.0; slip_surf_span  = 60.0;
  slip_surf_tone_w = 0.88;  slip_surf_noise_w = 0.32;
  slip_surf_drive  = 2.2;   slip_surf_gain   = 1.00;
  slip_surf_lfo_fm = 22.0;  slip_surf_chop_w  = 0.0;
  surface_type == 1 ? ( // Concrete: чистіший, вищий ~800 Гц, більше tone
    slip_surf_base   = 760.0; slip_surf_span  = 38.0;
    slip_surf_tone_w = 1.05;  slip_surf_noise_w = 0.18;
    slip_surf_drive  = 2.6;   slip_surf_gain   = 1.08;
    slip_surf_lfo_fm = 18.0;  slip_surf_chop_w  = 0.0;
  ) : surface_type == 2 ? ( // Gravel: переважно шум, нижча ~480 Гц, choppy
    slip_surf_base   = 440.0; slip_surf_span  = 80.0;
    slip_surf_tone_w = 0.35;  slip_surf_noise_w = 0.85;
    slip_surf_drive  = 1.4;   slip_surf_gain   = 0.72;
    slip_surf_lfo_fm = 38.0;  slip_surf_chop_w  = 0.30;
  ) : surface_type == 3 ? ( // Wet: м'який, ~580 Гц, тон приглушений
    slip_surf_base   = 530.0; slip_surf_span  = 50.0;
    slip_surf_tone_w = 0.55;  slip_surf_noise_w = 0.55;
    slip_surf_drive  = 1.6;   slip_surf_gain   = 0.82;
    slip_surf_lfo_fm = 14.0;  slip_surf_chop_w  = 0.0;
  );
  // 4-wheel chorus: base freq wanders slowly, each wheel micro-detuned
  slip_lfo_phase += 0.42 / srate;  // ~2.4 sec period
  slip_lfo_phase >= 1.0 ? slip_lfo_phase -= 1.0;
  slip_freq_wander_tgt += rand_noise() * 0.0025;
  slip_freq_wander_tgt = max(-1.0, min(1.0, slip_freq_wander_tgt));
  slip_freq_wander += (slip_freq_wander_tgt - slip_freq_wander) * 0.0020;
  slip_base_freq = slip_surf_base + slip_speed_norm * 380.0 + slip_env * 190.0
                 + slip_freq_wander * slip_surf_span
                 + sin(slip_lfo_phase * pi2) * slip_surf_lfo_fm;
  // Wheel 1 (main)
  slip_tone_phase += slip_base_freq / srate;
  slip_tone_phase >= 1.0 ? slip_tone_phase -= 1.0;
  // Wheel 2: -1.2% detune + slow LFO
  slip_w2_step = slip_base_freq * (0.988 + sin((slip_lfo_phase * 1.35 + 0.17) * pi2) * 0.0020);
  slip_w2_phase += slip_w2_step / srate;
  slip_w2_phase >= 1.0 ? slip_w2_phase -= 1.0;
  // Wheel 3: +1.1% detune
  slip_w3_step = slip_base_freq * (1.011 + sin((slip_lfo_phase * 1.09 + 0.53) * pi2) * 0.0018);
  slip_w3_phase += slip_w3_step / srate;
  slip_w3_phase >= 1.0 ? slip_w3_phase -= 1.0;
  // Wheel 4: +2.4% detune (most detuned, rear axle)
  slip_w4_step = slip_base_freq * (1.024 + sin((slip_lfo_phase * 0.91 + 0.81) * pi2) * 0.0022);
  slip_w4_phase += slip_w4_step / srate;
  slip_w4_phase >= 1.0 ? slip_w4_phase -= 1.0;
  slip_chorus = target_chorus_color;
  slip_h2_w1 = 0.16 + slip_chorus * 0.18;
  slip_h2_w2 = 0.14 + slip_chorus * 0.16;
  slip_h2_w3 = 0.12 + slip_chorus * 0.14;
  slip_h2_w4 = 0.10 + slip_chorus * 0.12;
  // Each wheel: fundamental + 2nd harmonic
  slip_wh1 = sin(slip_tone_phase * pi2) + sin(slip_tone_phase * pi2 * 2.0) * slip_h2_w1;
  slip_wh2 = sin(slip_w2_phase   * pi2) + sin(slip_w2_phase   * pi2 * 2.0) * slip_h2_w2;
  slip_wh3 = sin(slip_w3_phase   * pi2) + sin(slip_w3_phase   * pi2 * 2.0) * slip_h2_w3;
  slip_wh4 = sin(slip_w4_phase   * pi2) + sin(slip_w4_phase   * pi2 * 2.0) * slip_h2_w4;
  slip_wheel_mix = (slip_wh1 + slip_wh2 * 0.82 + slip_wh3 * 0.76 + slip_wh4 * 0.70) * 0.30;
  // Gravel choppy interrupt (stick-slip на гравії)
  slip_surf_chop_w > 0.0 ? (
    slip_wheel_mix *= (1.0 - slip_surf_chop_w + slip_surf_chop_w * (0.5 + abs(sin(slip_lfo_phase * pi2 * 7.3)) * 0.5));
  );
  // Soft-clip: глибина залежить від поверхні
  slip_chorus_drive = 0.78 + slip_chorus * 0.55;
  slip_tone_drv = slip_wheel_mix * slip_surf_drive * slip_chorus_drive;
  slip_tone = slip_tone_drv / (1.0 + abs(slip_tone_drv));
  // Drift loudness now scales with brake character for unified sound
  brake_squeal_influence = max(0.0, target_brake_squeal - 0.20) * 1.15;  
  brake_overtone_influence = target_brake_overtone * 0.85;
  slip_loud = (0.45 + target_drift_aggr * 0.90) * (0.92 + brake_squeal_influence * 0.45 + brake_overtone_influence * 0.35);
  // Плавний attack (~8ms) / release (~40ms) — без миттєвих стрибків (кліків)
  slip_atk_tc = 1.0 - exp(-1.0 / (srate * 0.008));
  slip_rel_tc = 1.0 - exp(-1.0 / (srate * 0.040));
  slip_env_tgt = slip_env + slip_burst_env * 0.28;
  slip_env_smooth += (slip_env_tgt - slip_env_smooth)
                     * (slip_env_tgt > slip_env_smooth ? slip_atk_tc : slip_rel_tc);
  slip_sig = (slip_tone * slip_surf_tone_w + slip_band * slip_surf_noise_w)
             * slip_env_smooth * slip_surf_gain * slip_loud;
  slip_road_add = slip_sig * (0.24 + low_gear_texture * 0.16) * (0.55 + norm_speed * 0.65);
  slip_chassis_lp += (slip_sig - slip_chassis_lp) * 0.018;
  slip_chassis_add = slip_chassis_lp * (0.06 + target_size * 0.08) * (0.35 + norm_speed * 0.45);
  // Direct brakes bus contribution: full-level slip signal, independent of road attenuation
  // This ensures drift squeal matches brake squeal loudness on the Brakes output
  slip_direct_loud = target_drift_aggr * (1.0 + brake_squeal_influence * 0.80 + brake_overtone_influence * 0.50);
  slip_direct = slip_sig * slip_direct_loud * 2.50;
  
  // Motion gate: hard silence near standstill, smooth rise from low speed
  motion_gate = max(0.0, (norm_speed - 0.040) / 0.090);
  motion_gate = min(motion_gate, 1.0);
  motion_gate *= motion_gate;

  // Speed dependence with floor tied to actual motion (no constant hiss at stop)
  road_floor = min((0.04 + cur_throttle * 0.10) * motion_gate, 0.22);
  road_gain = (road_floor + pow(norm_speed, 0.95) * 1.05) * motion_gate;
  chassis_gain = min(0.24 + pow(norm_speed, 0.82) * 1.05, 1.35);

  // Safety floor from contact/tread so Road bus is always audible while moving
  road_floor_sig = (abs(tire_contact) * 0.06 + abs(tire_tread) * 0.04) * (0.5 + norm_speed * 0.8);
  chassis_floor_sig = (abs(chassis_rumble) * 0.05) * (0.6 + norm_speed * 0.6);

  road_out = road_mix * target_road * road_gain * 0.62 * low_gear_gain * stop_noise_env;
  chassis_out = chassis_mix * target_chassis * chassis_gain * 0.52 * low_gear_gain * motion_gate * stop_noise_env;
  // Drift/slip → Brakes bus (directly matched to brake squeal level)
  slip_brakes_add = (slip_road_add + slip_chassis_add * 0.55 + slip_direct) * stop_noise_env;
) : (
  road_out = 0.0;
  chassis_out = 0.0;
  slip_brakes_add = 0.0;
  // Smooth flush of all filter states
  road_contact_lp1 *= 0.992;
  road_contact_lp2 *= 0.992;
  road_spray_lp *= 0.992;
  road_rumble_lpf *= 0.990;
  road_sub_lpf *= 0.990;
  road_grain *= 0.990;
  slip_env *= 0.92;
  slip_burst_env *= 0.88;
  slip_hold = 0;
  slip_noise_lp *= 0.92;
  slip_noise_hp *= 0.92;
  slip_scream_lp *= 0.88;
  slip_chassis_lp *= 0.90;
  slip_env_smooth *= 0.90;
  gravel_env *= 0.90;
  gravel_lp *= 0.97;
);

// Starter / Cranking Noise (Electric motor whine + compression groan)
starter_out = 0.0;
starter_den = cold_start * 2.0 + 0.1;
starter_t = min(max(starter_timer / starter_den, 0.0), 1.0);

// Smooth starter gate prevents abrupt jump from starter noise to engine hum
starter_gate_tgt = engine_state == 1 ? 1.0 : 0.0;
starter_env_tc = starter_gate_tgt > starter_env ? 0.010 : 0.220;
starter_env_coeff = 1.0 - exp(-1.0 / (srate * starter_env_tc));
starter_env += (starter_gate_tgt - starter_env) * starter_env_coeff;

// Cranking rotor speed with inertia and jitter for more mechanical realism
// Larger engine = lower base Hz, slower oscillation range
starter_rpm_tgt = engine_state == 1 ? (
  (270.0 - target_size * 80.0) + (1.0 - starter_t) * (155.0 - target_size * 45.0) + pink_noise * 35.0 + abs(rand_noise()) * 20.0
) : (
  210.0 + min(cur_rpm, 1200.0) * 0.055
);
starter_rpm_s += (starter_rpm_tgt - starter_rpm_s) * 0.020;
starter_phase += (starter_rpm_s / 60.0) / srate;
starter_phase >= 1.0 ? starter_phase -= 1.0;

// Variable-speed chopper: large engine = slower heavy lurching, small = fast clicks
starter_chop_rate_tgt = engine_state == 1 ? (
  (2.8 - target_size * 1.2) + (1.0 - starter_t) * (5.5 + target_size * 4.0) + abs(rand_noise()) * 1.4
) : 1.9;
starter_chop_rate += (starter_chop_rate_tgt - starter_chop_rate) * 0.0035;
starter_chop_phase += starter_chop_rate / srate;
starter_chop_phase >= 1.0 ? starter_chop_phase -= 1.0;
starter_chop_lfo += (0.22 + (1.0 - starter_t) * 0.95) / srate;
starter_chop_lfo >= 1.0 ? starter_chop_lfo -= 1.0;
starter_chop_raw = sin(starter_chop_phase * pi2 + sin(starter_chop_lfo * pi2) * 0.75);
starter_chop = 0.38 + 0.62 * max(0.0, starter_chop_raw);

// Grittier texture (less soft than pink-noise-only starter)
starter_white = rand_noise();
starter_noise_lp += (starter_white - starter_noise_lp) * 0.055;
starter_grit = starter_white - starter_noise_lp;
starter_grit = starter_grit / (1.0 + abs(starter_grit) * 2.8);

// Starter tone stack — amplitudes and frequencies scaled by engine size
// Small engine: high-pitch clean whine, light chatter
// Large engine: deep groan, heavy chatter, gritty texture
s_whine = sin(starter_phase * pi2 * (12.5 - target_size * 2.0) + starter_grit * 0.35) * (0.032 - target_size * 0.010);
s_base = (abs(sin(starter_phase * pi2 + pink_noise * 0.15)) - 0.5) * (0.042 + target_size * 0.068);
s_load = sin(starter_phase * pi2 * target_cylinders * 0.5 + starter_chop * 0.25);
s_groan = s_load * (0.055 + target_size * 0.075 + (1.0 - starter_t) * (0.038 + target_size * 0.082)) * (1.0 + starter_grit * (0.7 + target_size * 0.5));
s_chatter = (starter_chop - 0.5) * (0.055 + target_size * 0.095 + (1.0 - starter_t) * (0.045 + target_size * 0.090));

starter_noise = s_whine + s_base + s_groan + starter_grit * (0.022 + target_size * 0.090) + s_chatter;
starter_noise *= (0.55 + starter_chop * 0.75);
starter_out = starter_noise * starter_env * (0.85 + (1.0 - starter_t) * 0.35) * (0.62 + target_size * 0.68);

// 6. Routing & Processing Buses
bus_exhaust = mono_out; // Tailpipe / muffled exhaust radiation
// About -10 dB vs previous jolt level
shift_jolt_amt = target_shift_jolt * 0.76;
shift_scrape_amt = target_shift_scrape * 2.8;
bus_engine = core_out * 0.65; // Direct engine block/core sound for positioning
// Mech split contributes a light internal texture to engine core.
bus_engine += mech_engine_tex * (0.55 + target_mech * 0.35 + target_size * 0.16);
bus_bangs = sum_bangs * (0.86 + target_backfire_body * 0.44 + target_backfire_res * 0.32); // ALS/Backfire (dedicated output bus)
// Phase 5 gearbox character: continuous mesh, shift synchro whine, and speed-based differential hum.
gb_fwd = gear > 0 ? 1.0 : 0.0;
gb_rpm_w = min(max(cur_rpm / 9000.0, 0.0), 1.0);
gb_spd_w = min(max(veh_speed_norm, 0.0), 1.0);
gb_mesh_drive = (gb_rpm_w * 0.68 + gb_spd_w * 0.32) * gb_fwd;

gb_mesh_freq = 170.0 + cur_rpm * max(abs(gear_ratio), 0.08) * 0.11 + gb_spd_w * 145.0;
gb_mesh_lfo += (0.7 + gb_spd_w * 2.0) / srate;
gb_mesh_lfo >= 1.0 ? gb_mesh_lfo -= 1.0;
gb_mesh_phase += gb_mesh_freq / srate;
gb_mesh_phase >= 1.0 ? gb_mesh_phase -= 1.0;
gb_mesh_car = sin(gb_mesh_phase * pi2) * 0.64 + sin(gb_mesh_phase * pi2 * 2.03) * 0.28 + sin(gb_mesh_phase * pi2 * 3.01) * 0.12;
gb_mesh_noise = pink_noise * 0.62 + rand_noise() * 0.38;
gb_mesh_mod = 0.78 + sin(gb_mesh_lfo * pi2) * 0.16;
gb_mesh_sig = (gb_mesh_car * gb_mesh_mod + gb_mesh_noise * 0.24) * target_gb_mesh * (0.06 + target_whine * 0.07) * gb_mesh_drive;

gb_shift_rise = max(shift_jolt_pulse_env - gb_shift_prev, 0.0);
gb_shift_prev = shift_jolt_pulse_env;
gb_shift_rise > 0.010 ? gb_syn_env = max(gb_syn_env, gb_shift_rise * (0.42 + target_shift_scrape * 0.28));
gb_syn_env *= 0.99955;
gb_syn_freq = 680.0 + max(abs(gear_ratio), 0.08) * 240.0 + gb_rpm_w * 260.0;
gb_syn_phase += gb_syn_freq / srate;
gb_syn_phase >= 1.0 ? gb_syn_phase -= 1.0;
gb_syn_sig = (sin(gb_syn_phase * pi2) + sin(gb_syn_phase * pi2 * 2.0) * 0.24) * gb_syn_env * target_gb_mesh * gb_fwd * 0.18 * target_shift_peak;

gb_diff_freq = 26.0 + gb_spd_w * 108.0;
gb_diff_phase += gb_diff_freq / srate;
gb_diff_phase >= 1.0 ? gb_diff_phase -= 1.0;
gb_diff_tone = sin(gb_diff_phase * pi2) * 0.74 + sin(gb_diff_phase * pi2 * 2.0) * 0.20;
gb_diff_lp += ((pink_noise * 0.70 + rand_noise() * 0.30) - gb_diff_lp) * (0.010 + gb_spd_w * 0.010);
gb_diff_sig = (gb_diff_tone + gb_diff_lp * 0.26) * target_gb_diff * pow(gb_spd_w, 0.82) * gb_fwd * 0.34;

bus_gearbox = shift_scrape * 2.2 * shift_scrape_amt + shift_jolt * 1.6 * shift_jolt_amt;
bus_gearbox += gb_mesh_sig + gb_diff_sig;
bus_mech = mech_out * 0.40 + starter_out + whine_out; // Keep continuous gearbox whine out of Shift bus
bus_interior = 0.0; // Reset each sample to avoid feedback-like accumulation
// Cold engine: extra LF piston/valve friction noise that fades as engine warms
engine_state == 2 ? (
  therm_fric_lp += (pink_noise - therm_fric_lp) * 0.004;
  bus_mech += therm_fric_lp * cold_fact * cold_fact * 0.28;
);
bus_air = turbo_whine + intake_out; // Pure airy elements
// Hard mute Air bus when both generators are intentionally disabled.
target_turbo <= 0.001 && target_intake <= 0.001 ? bus_air = 0.0;
bus_bov = turbo_bov; // Transients / BOV / Pshhhh
bus_road = road_out; // Road Noise
bus_chassis = chassis_out; // Separate low-end chassis rumble

// Phase 7: Optional Sci-Fi engine mode (Combustion / Hybrid / Electric).
sci_ev_tgt = target_sci_mode == 2 ? 1.0 :
  target_sci_mode == 1 ? min(max((1.0 - cur_throttle) * 0.72 + (0.42 - gb_rpm_w) * 0.36 + (target_hybrid_bias - 0.5) * 1.10, 0.0), 1.0) :
  0.0;
engine_state <= 0 ? sci_ev_tgt = 0.0;
sci_ev_mix += (sci_ev_tgt - sci_ev_mix) * (1.0 - exp(-1.0 / (srate * 0.090)));
sci_comb_mix = 1.0 - sci_ev_mix * 0.97;

sci_drive_freq = 62.0 + gb_spd_w * 860.0 + gb_rpm_w * 160.0 + cur_throttle * 90.0;
sci_ev_phase += sci_drive_freq / srate;
sci_ev_phase >= 1.0 ? sci_ev_phase -= 1.0;
sci_ev_phase2 += (sci_drive_freq * 1.92) / srate;
sci_ev_phase2 >= 1.0 ? sci_ev_phase2 -= 1.0;
sci_drive_sig = (sin(sci_ev_phase * pi2) * 0.74 + sin(sci_ev_phase2 * pi2) * 0.26) * target_ev_whine * sci_ev_mix * (0.08 + gb_spd_w * 0.20);

sci_inv_lfo += (0.45 + gb_spd_w * 2.2) / srate;
sci_inv_lfo >= 1.0 ? sci_inv_lfo -= 1.0;
sci_inv_freq_tgt = 760.0 + gb_spd_w * 1820.0 + sin(sci_inv_lfo * pi2) * 14.0;
sci_inv_freq_sm += (sci_inv_freq_tgt - sci_inv_freq_sm) * (1.0 - exp(-1.0 / (srate * 0.080)));
sci_inv_phase += sci_inv_freq_sm / srate;
sci_inv_phase >= 1.0 ? sci_inv_phase -= 1.0;
sci_inv_raw = sin(sci_inv_phase * pi2) * 0.78 + sin(sci_inv_phase * pi2 * 2.04) * 0.18;
sci_inv_sig = (sci_inv_raw / (1.0 + abs(sci_inv_raw) * 0.24)) * target_inverter * sci_ev_mix * (0.022 + gb_spd_w * 0.065);

sci_move_gate = max(0.0, min((gb_spd_w - 0.010) / 0.055, 1.0));
sci_regen_mode_mix = target_sci_mode == 2 ? 1.0 : target_sci_mode == 1 ? max(sci_ev_mix, 0.34 + target_hybrid_bias * 0.32) : sci_ev_mix;
sci_regen_tgt = target_regen * sci_regen_mode_mix * sci_move_gate * max(0.0, (0.34 - cur_throttle) / 0.34) * (0.42 + target_brake * 0.90);
engine_state <= 0 ? sci_regen_tgt = 0.0;
sci_regen_env += (sci_regen_tgt - sci_regen_env) * (sci_regen_tgt > sci_regen_env ? 0.0042 : 0.0028);
sci_low20 = max(0.0, min((0.0714286 - gb_spd_w) / 0.0714286, 1.0));
sci_high20 = 1.0 - sci_low20;
sci_regen_phase += (96.0 + gb_spd_w * 270.0) / srate;
sci_regen_phase >= 1.0 ? sci_regen_phase -= 1.0;
sci_regen_lp += ((pink_noise * 0.80 + rand_noise() * 0.20) - sci_regen_lp) * (0.014 + gb_spd_w * 0.012);
sci_regen_tex += (sci_regen_lp - sci_regen_tex) * (0.032 + gb_spd_w * 0.024);
sci_regen_bright = target_regen_timbre;
sci_regen_noise = (sci_regen_lp - sci_regen_tex) * ((1.04 - sci_regen_bright * 0.44) + sci_low20 * (0.24 - sci_regen_bright * 0.10));
sci_regen_tone = sin(sci_regen_phase * pi2) * (0.08 + sci_high20 * (0.24 + sci_regen_bright * 0.26)) +
  sin(sci_regen_phase * pi2 * 2.0) * (0.02 + sci_high20 * (0.06 + sci_regen_bright * 0.16));
sci_regen_sig = (sci_regen_noise * (0.96 - sci_regen_bright * 0.34) + sci_regen_tone * (0.70 + sci_regen_bright * 0.95)) * sci_regen_env * 0.82;

// Bonus: Siren (Police/Medical/Fire) + Horn -- routed to dedicated Siren/Horn bus.
siren_tgt = target_siren_on > 0 && target_ignition > 0.5 ? 1.0 : 0.0;
siren_env += (siren_tgt - siren_env) * (siren_tgt > siren_env ? 0.0035 : 0.0012);
siren_lfo_rate = target_siren_type == 0 ? 0.32 : target_siren_type == 1 ? 1.25 : 0.72;
siren_lfo += siren_lfo_rate / srate;
siren_lfo >= 1.0 ? siren_lfo -= 1.0;
siren_mod = (sin(siren_lfo * pi2) + 1.0) * 0.5;
target_siren_type == 0 ? (
  // Police wail: deep 340-620 Hz sweep with stronger harmonics for menace
  siren_freq = 340.0 + siren_mod * 280.0;
) : target_siren_type == 1 ? (
  // Medical yelp
  siren_freq = 760.0 + abs(sin(siren_lfo * pi2 * 1.9)) * 720.0;
) : (
  // Fire two-tone
  siren_freq = sin(siren_lfo * pi2) >= 0 ? 520.0 : 700.0;
);
siren_phase += siren_freq / srate;
siren_phase >= 1.0 ? siren_phase -= 1.0;
target_siren_type == 0 ? (
  siren_tone_raw = sin(siren_phase * pi2) * 0.60 + sin(siren_phase * pi2 * 2.0) * 0.26 + sin(siren_phase * pi2 * 3.0) * 0.14;
  siren_tone = siren_tone_raw / (1.0 + abs(siren_tone_raw * 1.8)) * 1.1;
) : (
  siren_tone = sin(siren_phase * pi2) * 0.76 + sin(siren_phase * pi2 * 2.0) * 0.16;
);
siren_sig = (siren_tone + pink_noise * 0.06) * target_siren_level * siren_env * (0.11 + target_cabin_amb * 0.06);

// Horn: two-tone automotive horn (active while held, no ignition requirement)
horn_tgt = target_horn_on > 0 ? 1.0 : 0.0;
horn_env += (horn_tgt - horn_env) * (horn_tgt > horn_env ? 0.22 : 0.10);
horn_phase  += 390.0 / srate;
horn_phase  >= 1.0 ? horn_phase  -= 1.0;
horn_phase2 += 311.0 / srate;
horn_phase2 >= 1.0 ? horn_phase2 -= 1.0;
horn_raw = sin(horn_phase  * pi2) * 0.55 + sin(horn_phase  * pi2 * 2.1) * 0.22 +
           sin(horn_phase2 * pi2) * 0.45 + sin(horn_phase2 * pi2 * 2.0) * 0.14;
horn_raw = horn_raw / (1.0 + abs(horn_raw * 1.4)) * 1.2;
horn_sig = horn_raw * horn_env * target_horn_level * 0.28;

bus_siren_horn = siren_sig + horn_sig;

// Phase 8: idle micro-popping, fuel pump priming buzz, and stress knock/ping.
idle_rpm_w = min(max((1200.0 - cur_rpm) / 520.0, 0.0), 1.0);
idle_thr_w = min(max((0.15 - cur_throttle) / 0.15, 0.0), 1.0);
idle_gate = engine_state == 2 ? idle_rpm_w * idle_thr_w : 0.0;
idle_pop_wait > 0 ? idle_pop_wait -= 1;
idle_prob = (0.000012 + idle_gate * target_idle_pop * 0.00080) * (0.65 + target_crackle * 0.70);
idle_pop_wait <= 0 && rand_noise() > (1.0 - idle_prob) ? (
  idle_pop_env = max(idle_pop_env, 0.55 + abs(rand_noise()) * 0.55);
  idle_pop_freq = 78.0 + abs(rand_noise()) * 120.0;
  idle_pop_wait = max(1, (srate * (0.018 + abs(rand_noise()) * 0.130)) | 0);
);
idle_pop_phase += idle_pop_freq / srate;
idle_pop_phase >= 1.0 ? idle_pop_phase -= 1.0;
idle_pop_noise = rand_noise() * 0.58 + pink_noise * 0.42;
idle_pop_sig = (sin(idle_pop_phase * pi2) * 0.52 + idle_pop_noise * 0.48) * idle_pop_env * idle_gate * target_idle_pop * sci_comb_mix;
idle_pop_env *= 0.992;

fuel_pump_timer > 0 ? (
  fuel_pump_timer -= 1;
  fuel_pump_tgt = target_fuel_pump;
) : (
  fuel_pump_tgt = 0.0;
);
fuel_pump_env += (fuel_pump_tgt - fuel_pump_env) * (fuel_pump_tgt > fuel_pump_env ? 0.0065 : 0.0018);
fuel_pump_phase += (72.0 + target_fuel_pump * 38.0) / srate;
fuel_pump_phase >= 1.0 ? fuel_pump_phase -= 1.0;
fuel_pump_lfo += 2.2 / srate;
fuel_pump_lfo >= 1.0 ? fuel_pump_lfo -= 1.0;
fuel_pump_noise = pink_noise * 0.62 + rand_noise() * 0.38;
fuel_pump_lp += (fuel_pump_noise - fuel_pump_lp) * 0.05;
fuel_pump_tone = sin(fuel_pump_phase * pi2) * 0.64 + sin(fuel_pump_phase * pi2 * 2.03) * 0.18;
fuel_pump_mod = 0.82 + sin(fuel_pump_lfo * pi2) * 0.14;
fuel_pump_sig = (fuel_pump_tone * fuel_pump_mod + (fuel_pump_noise - fuel_pump_lp) * 0.35) * fuel_pump_env * target_fuel_pump * 0.18;

knock_stress_rpm = min(max((cur_rpm - limiter_rpm * 0.82) / max(limiter_rpm * 0.18, 1.0), 0.0), 1.0);
knock_stress_thr = min(max((cur_throttle - 0.62) / 0.38, 0.0), 1.0);
knock_gate = engine_state == 2 ? knock_stress_rpm * knock_stress_thr * sci_comb_mix : 0.0;
knock_wait > 0 ? knock_wait -= 1;
knock_prob = 0.000008 + knock_gate * target_knock_ping * 0.00125;
knock_wait <= 0 && rand_noise() > (1.0 - knock_prob) ? (
  knock_env = max(knock_env, 0.62 + abs(rand_noise()) * 0.65);
  knock_freq = 3400.0 + abs(rand_noise()) * 2500.0;
  knock_wait = max(1, (srate * (0.016 + abs(rand_noise()) * 0.085)) | 0);
);
knock_phase += knock_freq / srate;
knock_phase >= 1.0 ? knock_phase -= 1.0;
knock_sig = (sin(knock_phase * pi2) * 0.74 + rand_noise() * 0.26) * knock_env * knock_gate * target_knock_ping * 0.12;
knock_env *= 0.986;

bus_exhaust *= (1.0 - sci_ev_mix);
bus_bangs *= (1.0 - sci_ev_mix);
bus_engine *= (1.0 - sci_ev_mix * 0.74);
bus_mech *= (1.0 - sci_ev_mix * 0.48);
bus_engine += sci_drive_sig;
bus_air += sci_drive_sig * 0.16;
bus_mech += sci_inv_sig * 0.42 + sci_regen_sig;
sci_interior_sig = 0;
bus_bangs += idle_pop_sig * (0.62 + target_crackle * 0.40);
bus_exhaust += idle_pop_sig * (0.30 + target_backfire_body * 0.26);
bus_engine += knock_sig;
bus_mech += knock_sig * 0.55 + fuel_pump_sig * 0.35;

// Optional turn influence: subtle motion/weight-transfer style modulation when turn FX is active.
turn_active = target_ind_mode == 1 || target_ind_mode == 2 || target_ind_mode == 3;
turn_gate = turn_active ? 1.0 : 0.0;
turn_speed_w = min(max(norm_speed * 1.95 + 0.12, 0.0), 1.0);
turn_tgt = target_turn_infl * turn_gate * turn_speed_w;
turn_tc = turn_tgt > turn_inf_env ? 0.070 : 0.120;
turn_coeff = 1.0 - exp(-1.0 / (srate * turn_tc));
turn_inf_env += (turn_tgt - turn_inf_env) * turn_coeff;
turn_inf_phase += (0.65 + norm_speed * 2.80) / srate;
turn_inf_phase >= 1.0 ? turn_inf_phase -= 1.0;
turn_wob = sin(turn_inf_phase * pi2) * 0.72 + sin(turn_inf_phase * pi2 * 2.0 + 0.7) * 0.28;
turn_noise = (pink_noise * 0.55 + rand_noise() * 0.45);
turn_sig = (turn_wob * 0.62 + turn_noise * 0.38) * turn_inf_env;
bus_road += turn_sig * (0.110 + target_drift_aggr * 0.110);
bus_chassis += turn_sig * (0.072 + target_size * 0.032);
bus_engine += turn_sig * (0.026 + target_drive * 0.018);
bus_gearbox += turn_sig * (0.014 + target_whine * 0.020);

// Shutdown sputter generator: short uneven "pih-pih" bursts after ignition OFF
shutoff_pop_gap -= 1;
shutoff_pop_left > 0 && shutoff_pop_gap <= 0 ? (
  shutoff_pop_env = max(shutoff_pop_env, 0.72 + target_size * 0.45 + abs(rand_noise()) * 0.22);
  shutoff_pop_left -= 1;
  shutoff_pop_gap = max(1, (srate * (0.040 + abs(rand_noise()) * (0.060 + target_size * 0.045))) | 0);
);
shutoff_pop_env *= 0.9962;
shutoff_noise = rand_noise() * 0.72 + pink_noise * 0.28;
shutoff_noise_lp += (shutoff_noise - shutoff_noise_lp) * (0.075 + target_size * 0.03);
shutoff_hiss = shutoff_noise - shutoff_noise_lp;
shutoff_phase += (28.0 + target_size * 44.0 + shutoff_pop_env * 80.0) / srate;
shutoff_phase >= 1.0 ? shutoff_phase -= 1.0;
shutoff_body = sin(shutoff_phase * pi2) * 0.42 + shutoff_hiss * 0.58;
shutoff_sig = shutoff_body * shutoff_pop_env;
bus_bangs += shutoff_sig * (0.80 + target_size * 0.35);
bus_exhaust += shutoff_sig * (0.24 + target_size * 0.10);

// Wind noise: speed-dependent turbulence + low-frequency gust thumps (wind hitting microphone)
_wn = rand_noise();
wind_lp1   += (_wn      - wind_lp1)   * wind_lp_coeff; // LP at 3.2 kHz
wind_lp_lo += (wind_lp1 - wind_lp_lo) * wind_hp_coeff; // LP at 160 Hz (used to create HP)
_wind_sig  = wind_lp1 - wind_lp_lo;                    // band: 160 Hz..3.2 kHz
_wind_spd = veh_speed_norm;
_wind_spd2 = _wind_spd * _wind_spd;                    // quadratic with speed

// Faster and deeper modulation as speed rises (fixes "only volume grows" behavior)
wind_rate1 = 0.55 + _wind_spd * 6.80;                  // 0.55..7.35 Hz
wind_rate2 = 1.70 + _wind_spd * 11.0;                  // 1.7..12.7 Hz flutter
wind_lfo += wind_rate1 / srate; wind_lfo >= 1.0 ? wind_lfo -= 1.0;
wind_lfo2 += wind_rate2 / srate; wind_lfo2 >= 1.0 ? wind_lfo2 -= 1.0;
_wind_depth = 0.25 + _wind_spd * 0.62;                 // deeper swings at high speed
_wind_base = 0.78 + _wind_spd * 0.22;
_wind_turb = _wind_base
  + sin(wind_lfo * pi2) * _wind_depth * 0.55
  + sin(wind_lfo2 * pi2 + pink_noise * 0.15) * _wind_depth * 0.25;
_wind_turb = min(max(_wind_turb, 0.18), 1.55);

// Low-frequency "blow" events like wind hitting mic capsule/pop-filter
wind_gust_cnt <= 0 ? (
  _gust_thr = 0.999985 - _wind_spd2 * 0.000070 - target_wind * 0.000020;
  rand_noise() > _gust_thr ? (
    wind_gust_tgt = 0.45 + abs(rand_noise()) * 0.85;
    wind_gust_cnt = max(1, (srate * (0.045 + abs(rand_noise()) * 0.140)) | 0);
  ) : (
    wind_gust_tgt = 0.0;
    wind_gust_cnt = max(1, (srate * (0.012 + abs(rand_noise()) * 0.045)) | 0);
  );
) : wind_gust_cnt -= 1;
gust_tc = wind_gust_tgt > wind_gust_env ? 0.010 : 0.140;
gust_coeff = 1.0 - exp(-1.0 / (srate * gust_tc));
wind_gust_env += (wind_gust_tgt - wind_gust_env) * gust_coeff;
wind_gust_lp += (_wn - wind_gust_lp) * (0.003 + _wind_spd * 0.006);
_wind_thump = wind_gust_lp * wind_gust_env * (0.10 + _wind_spd * 0.34) * target_wind;

bus_wind = (_wind_sig * _wind_spd2 * target_wind * _wind_turb * 3.2) + _wind_thump;

// BRAKE SYNTHESIS: nonlinear staged model + surface dependence
cur_brake += (target_brake - cur_brake) * (1.0 - exp(-1.0 / (srate * 0.032)));

// Speed estimate from RPM/gear (0..1)
brake_speed_norm = gear > 0 ? min(1.0, (cur_rpm / max(gear_ratio, 0.01)) / 2800.0) : min(1.0, cur_rpm / 2800.0);
brake_active = cur_brake * brake_speed_norm;
brake_press_gate = max(0.0, (cur_brake - 0.01) / 0.99);
brake_press_gate *= brake_press_gate;

// Nonlinear pressure zones (non-normalized to keep stage-1 audible)
// 0..30%: light friction + crunch
// 30..60%: friction character peak
// 60..100%: squeal dominant
brk_low_w = max(0.0, (0.30 - cur_brake) / 0.30);
brk_mid_w = max(0.0, 1.0 - abs(cur_brake - 0.45) / 0.22);
brk_hi_w = max(0.0, (cur_brake - 0.60) / 0.40);

// Surface response shaping
sq_surf = 0.92; fr_surf = 1.00; cr_surf = 1.00; wet_hiss = 0.0;
surface_h1_base = 825.0;
surface_h1_span = 25.0;
surface_fm_scale = 1.00;
surface_scrm_scale = 1.00;
surface_chop_thresh_off = 0.00;
surface_lag_boost = 0.00;
surface_type == 1 ? ( // Concrete
  sq_surf = 1.08; fr_surf = 1.12; cr_surf = 0.90;
  surface_h1_base = 900.0; surface_h1_span = 22.0;
  surface_fm_scale = 1.10; surface_scrm_scale = 1.12;
  surface_chop_thresh_off = 0.05; surface_lag_boost = -0.04;
) : surface_type == 2 ? ( // Gravel
  sq_surf = 0.40; fr_surf = 0.98; cr_surf = 1.70;
  surface_h1_base = 760.0; surface_h1_span = 34.0;
  surface_fm_scale = 0.86; surface_scrm_scale = 0.80;
  surface_chop_thresh_off = -0.16; surface_lag_boost = 0.22;
) : surface_type == 3 ? ( // Wet
  sq_surf = 0.66; fr_surf = 0.86; cr_surf = 0.62; wet_hiss = 0.26;
  surface_h1_base = 790.0; surface_h1_span = 28.0;
  surface_fm_scale = 0.78; surface_scrm_scale = 0.82;
  surface_chop_thresh_off = -0.04; surface_lag_boost = 0.08;
);

// 1) Squeal: Harmonic series driven purely by road surface, no user pitch offset
brake_h1_base = surface_h1_base;
brake_h1_span = surface_h1_span;
// Continuous wander (no sample-and-hold steps): filtered noise + ultra-slow sinus drift
brake_h1_wander_tgt += rand_noise() * 0.0032;
brake_h1_wander_tgt > 1.0 ? brake_h1_wander_tgt = 1.0;
brake_h1_wander_tgt < -1.0 ? brake_h1_wander_tgt = -1.0;
brake_h1_wander += (brake_h1_wander_tgt - brake_h1_wander) * 0.0018;
brake_h1_wander2 += (sin((brake_lfo_phase * 0.63 + 0.21) * pi2) - brake_h1_wander2) * 0.0028;
brake_h1_freq = brake_h1_base + brake_h1_wander * (brake_h1_span * 0.72) + brake_h1_wander2 * (brake_h1_span * 0.28);
// Long-term modulation with subtle drift (calmer spectral movement)
brake_lfo_phase += 0.38 / srate;  // ~2.6 sec period
brake_lfo_phase >= 1.0 ? brake_lfo_phase -= 1.0;
brake_lfo_mod = sin(brake_lfo_phase * pi2) * 0.028;  // subtle phase flutter only
brake_fm_hz = (sin(brake_lfo_phase * pi2) * 8.0 + sin((brake_lfo_phase * 2.0 + 0.17) * pi2) * 2.0) * surface_fm_scale; // surface-dependent drift

h1_step = max(120.0, brake_h1_freq + brake_fm_hz);
h2_step = max(240.0, brake_h1_freq * 2.0 + brake_fm_hz * 0.92);
h3_step = max(360.0, brake_h1_freq * 3.0 + brake_fm_hz * 0.78);
h4_step = max(480.0, brake_h1_freq * 4.0 + brake_fm_hz * 0.62);
h5_step = max(600.0, brake_h1_freq * 5.0 + brake_fm_hz * 0.48);

brake_h1_phase += h1_step / srate;
brake_h1_phase >= 1.0 ? brake_h1_phase -= 1.0;
brake_h2_phase += h2_step / srate;
brake_h2_phase >= 1.0 ? brake_h2_phase -= 1.0;
brake_h3_phase += h3_step / srate;
brake_h3_phase >= 1.0 ? brake_h3_phase -= 1.0;
brake_h4_phase += h4_step / srate;
brake_h4_phase >= 1.0 ? brake_h4_phase -= 1.0;
brake_h5_phase += h5_step / srate;
brake_h5_phase >= 1.0 ? brake_h5_phase -= 1.0;

// 4-wheel cluster near the top of squeal slider: each wheel has own micro detune/mod
squeal_edge = max(0.0, (target_brake_squeal - 0.82) / 0.18);
squeal_edge *= squeal_edge;
w2_step = max(120.0, brake_h1_freq * (0.988 + sin((brake_lfo_phase * 1.37 + 0.13) * pi2) * 0.0016));
w3_step = max(120.0, brake_h1_freq * (1.011 + sin((brake_lfo_phase * 1.11 + 0.47) * pi2) * 0.0018));
w4_step = max(120.0, brake_h1_freq * (1.024 + sin((brake_lfo_phase * 0.93 + 0.79) * pi2) * 0.0020));
brake_w2_phase += w2_step / srate;
brake_w2_phase >= 1.0 ? brake_w2_phase -= 1.0;
brake_w3_phase += w3_step / srate;
brake_w3_phase >= 1.0 ? brake_w3_phase -= 1.0;
brake_w4_phase += w4_step / srate;
brake_w4_phase >= 1.0 ? brake_w4_phase -= 1.0;

// Detuning for natural shimmer
h1_detune = 1.0 + sin(t_brk * 0.8 * pi2) * 0.015;
h2_detune = 1.0 + cos(t_brk * 1.2 * pi2) * 0.012;
h3_detune = 1.0 - sin(t_brk * 0.6 * pi2) * 0.010;

// Harmonics with modulation and dense screamer core
h1_out = sin(brake_h1_phase * pi2 * (1.0 + brake_lfo_mod)) * 1.00;
h2_out = sin(brake_h2_phase * pi2 * (1.0 + brake_lfo_mod * 0.72) * h1_detune) * 0.24;
h3_out = sin(brake_h3_phase * pi2 * (1.0 + brake_lfo_mod * 0.52) * h2_detune) * 0.10;
h4_out = sin(brake_h4_phase * pi2 * (1.0 + brake_lfo_mod * 0.32) * h3_detune) * 0.05;
h5_out = sin(brake_h5_phase * pi2 * (1.0 + brake_lfo_mod * 0.18)) * 0.015;

// Aggressive overtone drive (user-controlled)
overtone_drive = pow(target_brake_overtone, 1.25);
h2_out *= (1.0 + overtone_drive * 2.10);
h3_out *= (1.0 + overtone_drive * 3.20);
h4_out *= (1.0 + overtone_drive * 4.80);
h5_out *= (1.0 + overtone_drive * 6.50);

brake_sq_gate = max(0.0, (cur_brake - 0.52) / 0.48);
brake_sq_tone = h1_out + h2_out + h3_out + h4_out + h5_out;
// Drift-style 4-wheel chorus for brake squeal: harmonic wheels + soft-clip glue.
brake_chorus = target_chorus_color;
brk_h2_w1 = 0.14 + brake_chorus * 0.18;
brk_h2_w2 = 0.12 + brake_chorus * 0.16;
brk_h2_w3 = 0.10 + brake_chorus * 0.14;
brk_h2_w4 = 0.08 + brake_chorus * 0.12;
wheel1 = sin(brake_h1_phase * pi2) + sin(brake_h1_phase * pi2 * 2.0) * brk_h2_w1;
wheel2 = sin(brake_w2_phase * pi2) + sin(brake_w2_phase * pi2 * 2.0) * brk_h2_w2;
wheel3 = sin(brake_w3_phase * pi2) + sin(brake_w3_phase * pi2 * 2.0) * brk_h2_w3;
wheel4 = sin(brake_w4_phase * pi2) + sin(brake_w4_phase * pi2 * 2.0) * brk_h2_w4;
wheel_mix = (wheel1 + wheel2 * 0.82 + wheel3 * 0.76 + wheel4 * 0.70) * 0.285;
brake_chorus_drive = 0.82 + brake_chorus * 0.52;
wheel_drv = wheel_mix * (1.55 + squeal_edge * 0.85) * brake_chorus_drive;
wheel_sat = wheel_drv / (1.0 + abs(wheel_drv));
wheel_bite = wheel_sat - wheel_sat * abs(wheel_sat);
wheel_air = wheel_bite * wheel_sat;
brake_sq_tone += wheel_sat * (0.05 + squeal_edge * 0.22);
brake_sq_tone += wheel_bite * (0.02 + squeal_edge * 0.14);
brake_sq_tone += wheel_air * (0.00 + squeal_edge * 0.08);
brake_sq_tone *= (0.88 + surface_scrm_scale * 0.12);
brake_sq_tone *= (0.22 + cur_brake * 0.68);  // Normalized for multi-harmonic
brake_scrm_mix = (0.34 + cur_brake * 0.34) * surface_scrm_scale;
brake_scrm_edge = h3_out >= 0 ? 1.0 : -1.0;
brake_scrm_src = h2_out * 0.28 + h3_out * 0.24 + h4_out * 0.16 + h5_out * 0.06 + brake_scrm_edge * 0.032;
brake_scrm_lp += (brake_scrm_src - brake_scrm_lp) * (0.11 + cur_brake * 0.08);
brake_screamer = brake_scrm_src - brake_scrm_lp;
brake_screamer = brake_screamer > 0.0 ?
  min(brake_screamer * (1.70 + cur_brake * 0.72), 0.82) :
  max(brake_screamer * (1.52 + cur_brake * 0.64), -0.76);
brake_screamer *= (0.06 + brake_sq_gate * 0.18);
// Small crescendo ramp at end (when brake fully applied)
brake_crescendo = pow(max(0, (cur_brake - 0.75) / 0.25), 2.0) * 0.35;
brake_sq_tone = (brake_sq_tone + brake_screamer * brake_scrm_mix) * (1.0 + brake_crescendo);
brake_sq_tone_lp += (brake_sq_tone - brake_sq_tone_lp) * (0.040 + cur_brake * 0.018);
brake_sq_tone = brake_sq_tone_lp + (brake_sq_tone - brake_sq_tone_lp) * 0.24;

// Random stick-slip interruptions (physical grab/release feel)
brake_sq_chop_cnt <= 0 ? (
  rand_noise() > (0.90 + surface_chop_thresh_off - cur_brake * 0.10 - brake_speed_norm * 0.05) ? (
    brake_sq_chop_tgt = 0.52 + abs(rand_noise()) * 0.20;
  ) : (
    brake_sq_chop_tgt = 0.90 + abs(rand_noise()) * 0.10;
  );
  brake_sq_chop_cnt = max(1, (srate * ((0.045 + abs(rand_noise()) * 0.110) * (1.0 + surface_lag_boost * 0.75))) | 0);
) : (
  brake_sq_chop_cnt -= 1;
);
brake_sq_chop += (brake_sq_chop_tgt - brake_sq_chop) * (0.022 - surface_lag_boost * 0.006);

brake_squeal = brake_sq_tone * brake_sq_gate * pow(brake_speed_norm, 0.82) * sq_surf * brake_sq_chop * brake_press_gate;

// 2) Friction: drier metallic friction (less smooth ocean-like wash)
brake_fric_src = rand_noise() * 0.72 + pink_noise * 0.28;
brake_fric_lp1 += (brake_fric_src - brake_fric_lp1) * (0.026 + cur_brake * 0.014);
brake_fric_lp2 += (brake_fric_lp1 - brake_fric_lp2) * 0.0078;
brake_fric_band = brake_fric_lp1 - brake_fric_lp2;
brake_fric_lp3 += (brake_fric_band - brake_fric_lp3) * 0.34;
brake_fric_low += (brake_fric_lp3 - brake_fric_low) * 0.030;
brake_fric_mid = brake_fric_lp3 - brake_fric_low;
brake_fric_hi += (brake_fric_mid - brake_fric_hi) * 0.24;
brake_fric_air += (brake_fric_hi - brake_fric_air) * 0.05;
brake_fric_top = brake_fric_hi - brake_fric_air;
brake_fric_grit = brake_fric_band - brake_fric_band * abs(brake_fric_band) * 0.55;
brake_fric_hold_tgt = brake_press_gate * (0.18 + brk_mid_w * 0.24 + brk_hi_w * 0.34) * (0.62 + brake_speed_norm * 0.38);
brake_fric_hold += (brake_fric_hold_tgt - brake_fric_hold) * (brake_fric_hold_tgt > brake_fric_hold ? 0.040 : 0.004);

// Laggy friction envelope: step-like and less fluid, with occasional short drops
brake_fric_lag_cnt <= 0 ? (
  rand_noise() > (0.89 + surface_chop_thresh_off - cur_brake * 0.10 - brake_speed_norm * 0.06) ? (
    brake_fric_lag_tgt = 0.58 + abs(rand_noise()) * 0.20;
  ) : (
    brake_fric_lag_tgt = 0.86 + abs(rand_noise()) * 0.12;
  );
  brake_fric_lag_cnt = max(1, (srate * ((0.028 + abs(rand_noise()) * 0.095) * (1.0 + surface_lag_boost))) | 0);
) : (
  brake_fric_lag_cnt -= 1;
);
brake_fric_lag += (brake_fric_lag_tgt - brake_fric_lag) * (0.016 - surface_lag_boost * 0.005);

brake_fric = brake_fric_mid * (0.66 + brk_low_w * 0.40 + brk_mid_w * 1.18 + brk_hi_w * 0.56) * (0.42 + pow(brake_speed_norm, 0.56)) * fr_surf;
brake_fric += brake_fric_grit * brake_fric_hold * 0.62 * fr_surf;
brake_fric += brake_fric_top * (0.14 + brk_mid_w * 0.18 + brk_hi_w * 0.26 + brake_fric_hold * 0.30) * fr_surf;
brake_fric *= brake_fric_lag;
brake_fric *= brake_press_gate;

// 3) Crunch/body: mostly low pressure + gravel emphasis
brake_crunch_lp += ((pink_noise * cur_brake) - brake_crunch_lp) * 0.0022;
brake_crunch = brake_crunch_lp * (0.40 + brk_low_w * 1.30 + brk_mid_w * 0.42) * (0.78 + (1.0 - brake_speed_norm) * 0.32) * cr_surf * brake_press_gate;

// Wet adds a soft air hiss under braking
brake_wet = pink_noise * wet_hiss * cur_brake * brake_speed_norm * 0.35 * brake_press_gate;

// 4) Pad squeak: disc-friction oscillator — pure metal-on-metal tone, no road surface influence
// Clean constant frequency set by Brake Squeal Pitch slider; only micro drift from mechanical resonance
pad_sq_gate = max(0.0, min((cur_brake - 0.12) / 0.24, 1.0));
pad_sq_gate *= (0.58 + max(0.0, min((1.00 - cur_brake) / 0.32, 1.0)) * 0.42);
pad_sq_gate *= brake_speed_norm * sq_surf * (0.60 + cur_brake * 0.25);  // sq_surf scales amplitude only; pitch stays surface-independent
pad_disc_freq = 2200.0 + target_brake_pitch * 3400.0;  // 2200 Hz (pitch=0) .. 5600 Hz (pitch=1)
pad_disc_micro = pad_disc_freq * (1.0 + brake_h1_wander * 0.004);  // tiny structural resonance drift only
brake_pad_phase += pad_disc_micro / srate;
brake_pad_phase >= 1.0 ? brake_pad_phase -= 1.0;
pad_sq_gate > brake_pad_env ? (
  brake_pad_env += (pad_sq_gate - brake_pad_env) * 0.007;
) : (
  brake_pad_env += (pad_sq_gate - brake_pad_env) * 0.003;
);
brake_pad_squeak = sin(brake_pad_phase * pi2) * 0.22 * brake_pad_env * target_pad_squeak;

brake_mix_gain = 0.52 + brake_active * 1.68;
brake_squeal_level = pow(target_brake_squeal, 0.80);
brake_squeal_gain = brake_squeal_level * 2.40;
brake_tone_mix = brake_squeal * brake_mix_gain * 0.85 * brake_squeal_gain * target_brake_trim;
brake_noise_mix = (brake_fric * 0.68 + brake_crunch * 0.95 + brake_wet) * brake_mix_gain * 0.90 * target_brake_trim;

// Interruption lag envelope (amplitude only): stronger/longer near squeal slider = 100
brake_int_amt = pow(target_brake_squeal, 2.20);
brake_int_gap_cnt <= 0 ? (
  rand_noise() > (0.92 - brake_int_amt * 0.28 - cur_brake * 0.08) ? (
    brake_int_gap_tgt = 0.22 + abs(rand_noise()) * (0.30 - brake_int_amt * 0.10);
  ) : (
    brake_int_gap_tgt = 0.86 + abs(rand_noise()) * 0.12;
  );
  brake_int_gap_cnt = max(1, (srate * (0.010 + brake_int_amt * 0.095 + abs(rand_noise()) * 0.050)) | 0);
) : (
  brake_int_gap_cnt -= 1;
);
brake_int_gap += (brake_int_gap_tgt - brake_int_gap) * (0.030 - brake_int_amt * 0.016);
brake_interrupt = (1.0 - brake_int_amt) + brake_int_amt * brake_int_gap;
brake_tone_mix *= brake_interrupt;
brake_noise_mix *= (0.88 + brake_interrupt * 0.12);

bus_brakes = brake_tone_mix + brake_noise_mix;
bus_brakes += brake_pad_squeak * brake_mix_gain * target_brake_trim * 2.0;  // Pad squeak boost: makes it audible over friction noise
bus_brakes += slip_brakes_add;  // Drift/traction slip on Brakes bus

// HANDBRAKE (Phase 4): ratchet on pull, spring click on release, hold rumble while moving.
hb_target_delta = target_handbrake - prev_target_handbrake;
hb_pull = max(hb_target_delta, 0.0);
hb_release = max(-hb_target_delta, 0.0);

hb_pull > 0.0006 ? (
  hb_is_pulling = 1.0;
  hb_click_pending += 1.0 + hb_pull * 12.0;
  hb_click_pending = min(hb_click_pending, 3.5);
);

hb_is_pulling > 0.0 ? (
  hb_is_pulling -= 0.0015;
);

hb_ratchet_timer -= 1;
hb_ratchet_timer <= 0 && hb_click_pending >= 1.0 ? (
  hb_ratchet_env = max(hb_ratchet_env, (0.78 + cur_handbrake * 0.55) * target_hb_ratchet * (1.0 + hb_is_pulling * 1.8));
  hb_ratchet_phase = 0.0;
  hb_click_pending -= 1.0;
  hb_short_interval = hb_is_pulling > 0.2 ? 0.018 : 0.050;
  hb_ratchet_timer = max(1, (srate * (hb_short_interval + (1.0 - cur_handbrake) * 0.015 + abs(rand_noise()) * 0.010)) | 0);
);

hb_release > 0.0010 ? (
  hb_ratchet_env = max(hb_ratchet_env, min(1.25, (0.55 + hb_release * 120.0) * target_hb_release));
);

hb_ratchet_noise = rand_noise() * 0.55 + pink_noise * 0.45;
hb_ratchet_phase += (300.0 + cur_handbrake * 25.0) / srate;
hb_ratchet_phase >= 1.0 ? hb_ratchet_phase -= 1.0;
hb_ratchet_tone = sin(hb_ratchet_phase * pi2) * 0.42;
hb_harmonic1 = sin(hb_ratchet_phase * pi2 * 2.0) * 0.18;
hb_ratchet_raw = hb_ratchet_noise * 0.55 + hb_ratchet_tone * 0.38 + hb_harmonic1 * 0.14;
hb_ratchet_sig = (hb_ratchet_raw / (1.0 + abs(hb_ratchet_raw) * 0.55)) * hb_ratchet_env;
hb_ratchet_env *= 0.9988;

hb_release_sig = 0.0; // release now shares ratchet synthesis path

hb_hold_tgt = cur_handbrake * target_hb_hold * max(0.0, (veh_speed_norm - 0.02) / 0.98);
hb_hold_env += (hb_hold_tgt - hb_hold_env) * (hb_hold_tgt > hb_hold_env ? 0.009 : 0.020);
hb_hold_noise = pink_noise * 0.70 + rand_noise() * 0.30;
hb_hold_lp += (hb_hold_noise - hb_hold_lp) * (0.009 + cur_handbrake * 0.012);
hb_hold_hp += (hb_hold_lp - hb_hold_hp) * 0.12;
hb_hold_phase += (18.0 + veh_speed_norm * 26.0 + cur_handbrake * 10.0) / srate;
hb_hold_phase >= 1.0 ? hb_hold_phase -= 1.0;
hb_hold_sub = sin(hb_hold_phase * pi2) * 0.52;
hb_hold_sig = ((hb_hold_lp - hb_hold_hp) * 0.72 + hb_hold_sub * 0.60) * hb_hold_env;

hb_surface = surface_type == 0 ? 1.00 : surface_type == 1 ? 0.95 : surface_type == 2 ? 1.25 : 0.82;
bus_gearbox += (hb_ratchet_sig * 1.35 + hb_release_sig * 1.40 + hb_hold_sig * 1.18) * hb_surface;

// Direct engine/gearbox load feel from handbrake engagement while moving.
hb_load = cur_handbrake * (0.25 + veh_speed_norm * 0.75);
hb_rpm_w = min(max(cur_rpm / 9000.0, 0.0), 1.0);
hb_eng_phase += (18.0 + veh_speed_norm * 28.0 + hb_rpm_w * 24.0) / srate;
hb_eng_phase >= 1.0 ? hb_eng_phase -= 1.0;
hb_eng_growl = (sin(hb_eng_phase * pi2) * 0.65 + sin(hb_eng_phase * pi2 * 2.0 + 0.7) * 0.35)
  * hb_load * (0.055 + target_hb_hold * 0.045);
bus_engine *= 1.0 - hb_load * 0.16;
bus_gearbox *= 1.0 - hb_load * 0.22;
bus_engine += hb_eng_growl;
bus_gearbox += hb_eng_growl * 0.72;
prev_target_handbrake = target_handbrake;
prev_handbrake = cur_handbrake;

brake_press_gate <= 0 ? (
  brake_fric_hold = 0.0;
  brake_fric_lag = 1.0;
  brake_fric_lag_tgt = 1.0;
  brake_fric_lag_cnt = 0;
  brake_int_gap = 1.0;
  brake_int_gap_tgt = 1.0;
  brake_int_gap_cnt = 0;
  brake_h1_wander = 0.0;
  brake_h1_wander_tgt = 0.0;
  brake_h1_wander_cnt = 0;
  brake_h1_wander2 = 0.0;
  brake_w2_phase = 0.0;
  brake_w3_phase = 0.0;
  brake_w4_phase = 0.0;
  brake_scrm_lp = 0.0;
  brake_sq_tone_lp = 0.0;
  brake_sq_chop = 1.0;
  brake_sq_chop_tgt = 1.0;
  brake_sq_chop_cnt = 0;
  brake_pad_env = 0.0;
  cur_handbrake <= 0.001 ? bus_brakes = 0.0;
);

// Light engine-brake body feel for low pedal pressure
bus_chassis += brk_low_w * brake_active * (1.0 - cur_throttle) * 0.08;

// Engine-brake body pulse on closed throttle (gear-dependent via engine_brake_map)
ebrk_pulse = (abs(sin(phase_acc * pi2 * 0.5)) - 0.5) * 2.0;
bus_chassis += ebrk_pulse * engine_brake_map * (0.045 + norm_speed * 0.10) * (0.75 + target_size * 0.55);

// Cabin/Exterior scene crossfade (0 = cabin, 1 = exterior)
// Cabin: more body/mech/chassis, less wind/intake/exhaust brightness feel.
// Exterior: opposite perspective for pass-by / outside mic placement.
cabext_coeff = 1.0 - exp(-1.0 / (srate * 0.050));
cabext_mix += (target_cabext - cabext_mix) * cabext_coeff;
cabext_mix = min(max(cabext_mix, 0.0), 1.0);
ext_mix = cabext_mix;
// Nonlinear perspective shaping: center stays usable, ends are much more pronounced.
ext_focus = pow(ext_mix, 1.45);
cab_focus = pow(1.0 - ext_mix, 1.35);

bus_exhaust *= 0.26 + 0.94 * ext_focus;
bus_engine  *= 0.78 + 0.58 * cab_focus;
bus_mech    *= 0.62 + 0.88 * cab_focus;
bus_gearbox *= 0.60 + 0.82 * cab_focus;
bus_air     *= 0.24 + 0.96 * ext_focus;
bus_bov     *= 0.24 + 0.96 * ext_focus;
bus_road    *= 0.60 + 0.62 * cab_focus;
bus_chassis *= 0.54 + 0.86 * cab_focus;
bus_brakes  *= 0.66 + 0.46 * cab_focus;
bus_bangs   *= 0.36 + 0.92 * ext_focus;
bus_wind    *= 0.35 + 0.65 * ext_mix;

// Interior/Cabin bus: Reverse Beep + Indicator Relays + Cabin Ambiance
gb_shift_peak_interior = gb_syn_sig;
bus_interior += rev_beep_out + ind_click_out + cabin_amb_out + gb_shift_peak_interior + sci_interior_sig;

// Exhaust micro-granularity + soft interruptions (organic flutter)
engine_state > 0 ? (
  exh_grain_cnt <= 0 ? (
    exh_grain_tgt = 0.84 + abs(rand_noise()) * 0.30;
    exh_grain_cnt = max(1, (srate * (0.004 + (1.0 - cur_throttle) * 0.006)) | 0);
  ) : (
    exh_grain_cnt -= 1;
  );
  exh_grain += (exh_grain_tgt - exh_grain) * 0.02;

  // Rare short dips that feel like turbulent flow interruptions
  rand_noise() > (0.9993 - rpm_norm * 0.0008 - cur_throttle * 0.0005) ? exh_chop_env = 1.0;
  exh_chop_env *= (0.88 - rpm_norm * 0.05);
  exh_chop_depth = 0.06 + target_drive * 0.08 + cur_throttle * 0.05;
  exh_chop_gain = 1.0 - exh_chop_env * exh_chop_depth;

  // Smoker-like rasp: high-mid bandpassed turbulence (not pure white hiss)
  exh_rasp_src = rand_noise() * 0.7 + pink_noise * 0.3;
  exh_rasp_lp += (exh_rasp_src - exh_rasp_lp) * (0.07 + rpm_norm * 0.16);
  exh_rasp_air += (exh_rasp_src - exh_rasp_air) * (0.006 + rpm_norm * 0.02);
  exh_rasp_bp = exh_rasp_lp - exh_rasp_air;
  exh_rasp_env = (0.12 + rpm_norm * 0.90) * (0.35 + cur_throttle * 0.85) * (0.45 + target_drive * 0.95);
  exh_rasp = exh_rasp_bp * exh_rasp_env * 0.48;
  exh_rasp *= 1.0 + cold_fact * 0.45; // Cold combustion: richer mix adds rasp

  bus_exhaust = bus_exhaust * exh_grain * exh_chop_gain + exh_rasp;
) : (
  exh_grain = 1.0;
  exh_grain_tgt = 1.0;
  exh_grain_cnt = 0;
  exh_chop_env = 0.0;
  exh_rasp_lp = 0.0;
  exh_rasp_air = 0.0;
);

// Mild engine duck on traction slip so tire layer reads in full mix
slip_duck = min(max(slip_env * 0.65 + slip_burst_env * 0.45, 0.0), 1.0);
bus_engine *= 1.0 - slip_duck * (0.10 + target_drift_aggr * 0.16);
bus_exhaust *= 1.0 - slip_duck * (0.06 + target_drift_aggr * 0.10);

// Smooth ignition audio gate to prevent LF click on engine OFF
ign_audio_tgt = target_ignition ? 1.0 : 0.0;
ign_audio_tc = ign_audio_tgt > ign_audio_env ? 0.010 : ((shutoff_pop_left > 0 || shutoff_pop_env > 0.02) ? 0.220 : 0.070);
ign_audio_coeff = 1.0 - exp(-1.0 / (srate * ign_audio_tc));
ign_audio_env += (ign_audio_tgt - ign_audio_env) * ign_audio_coeff;
bus_exhaust *= ign_audio_env;
bus_engine *= ign_audio_env;
bus_mech *= ign_audio_env;
bus_gearbox *= ign_audio_env;
bus_air *= ign_audio_env;
bus_bov *= ign_audio_env;
bus_bangs *= ign_audio_env;

// Master Drive & Saturation (Only applies to Engine and Mech to prevent distorted Air)
  drive_gain = 1.0 + target_drive * 5.0; // 1x to 6x gain into saturator
  headroom = 0.5 + target_drive * 0.5; // 0.5 at Drive 0, 1.0 at Drive 1
  inv_drive = (1.0 / sqrt(drive_gain)) * headroom;

  // Drive Exhaust & Engine Core
  exhaust_drive = drive_gain * 1.10;
  bus_exhaust *= exhaust_drive;
  bus_exhaust += bus_exhaust * bus_exhaust * 0.06 * target_drive; // Softer 2nd harmonic for more natural rise
  // Зменшуємо агресію майстер-сатуратора на 50%
  bus_exhaust = bus_exhaust / (1.0 + abs(bus_exhaust * target_drive * 0.50));
  bus_exhaust *= inv_drive;

  bus_engine *= drive_gain * 0.9;
  bus_engine = bus_engine / (1.0 + abs(bus_engine * target_drive * 0.35));
  bus_engine *= inv_drive;

  bus_bangs *= drive_gain * 1.25; // Slight boost to bangs, less brittle top
  // Bangs stay slightly clipped even at 0 drive
  bus_bangs = bus_bangs / (1.0 + abs(bus_bangs * (0.2 + target_drive * 0.5)));
  bus_bangs *= inv_drive;

  // Darken ALS/Backfire highs for rougher, less piercing character
  bang_dark_fc = 650.0 + (1.0 - target_als) * 900.0;
  bang_dark_coeff = 1.0 - exp(-2.0 * pi * bang_dark_fc / srate);
  bang_dark_lpf += (bus_bangs - bang_dark_lpf) * bang_dark_coeff;
  bus_bangs = bang_dark_lpf * 0.85 + bus_bangs * 0.15;
  // Make ALS/backfire clearly audible above base exhaust
  als_bang_gain = 1.45 + target_als * 1.75;
  crackle_bang_gain = 1.00 + target_crackle * 0.35;
  bang_boost_full = als_bang_gain * crackle_bang_gain;
  bang_boost_mix = 1.0 + (bang_boost_full - 1.0) * 0.5; // halfway between old and boosted level
  bus_bangs *= bang_boost_mix;

  // Drive Mechanical
  bus_mech *= drive_gain;
  bus_mech = bus_mech / (1.0 + abs(bus_mech * target_drive * 0.3));
  bus_mech *= inv_drive;

  // Drive Gearbox
  bus_gearbox *= drive_gain * 1.15;
  bus_gearbox = bus_gearbox / (1.0 + abs(bus_gearbox * target_drive * 0.18));
  bus_gearbox *= inv_drive;

  // Brake ducking: attenuate only engine + exhaust while preserving road/mech physics layers
  brake_duck_tgt = min(1.0, brake_press_gate * (0.35 + brake_speed_norm * 0.65) * (0.55 + (1.0 - cur_throttle) * 0.45));
  brake_duck_ms = brake_duck_tgt > brake_duck_env ? 28.0 : 120.0;
  brake_duck_coeff = 1.0 - exp(-1.0 / (srate * (brake_duck_ms / 1000.0)));
  brake_duck_env += (brake_duck_tgt - brake_duck_env) * brake_duck_coeff;

  engine_brake_duck_gain = 1.0 - brake_duck_env * 0.58; // min ~0.42 at hard braking
  exhaust_brake_duck_gain = 1.0 - brake_duck_env * 0.45; // min ~0.55 at hard braking
  bus_engine *= engine_brake_duck_gain;
  bus_exhaust *= exhaust_brake_duck_gain;

// Total Tone / High-Cut (Remove digital harshness globally on all buses)
tone_fc = 20000.0 - target_tone * 18000.0;
tone_coeff = 1 - exp(-2 * pi * tone_fc / srate);

t_exh += (bus_exhaust - t_exh) * tone_coeff; bus_exhaust = t_exh;
t_core += (bus_engine - t_core) * tone_coeff; bus_engine = t_core;
t_gbx += (bus_gearbox - t_gbx) * tone_coeff; bus_gearbox = t_gbx;
t_mech += (bus_mech - t_mech) * tone_coeff; bus_mech = t_mech;
t_air += (bus_air - t_air) * tone_coeff; bus_air = t_air;
t_bov += (bus_bov - t_bov) * tone_coeff; bus_bov = t_bov;
t_road += (bus_road - t_road) * tone_coeff; bus_road = t_road;
t_chs += (bus_chassis - t_chs) * tone_coeff; bus_chassis = t_chs;
brake_tone_coeff = min(1.0, tone_coeff * 0.42 + 0.012);
t_brk += (brake_tone_mix - t_brk) * brake_tone_coeff;
bus_brakes = t_brk + brake_noise_mix;
bus_brakes += brake_pad_squeak * brake_mix_gain * target_brake_trim * 0.8;  // Keep pad squeak present but clearly under the main brake texture
bus_brakes += slip_brakes_add;  // Drift/traction slip on Brakes bus

// 7. DC Blockers per bus
dc_out_ex = bus_exhaust - dc_in_ex + dc_pole * dc_out_ex; dc_in_ex = bus_exhaust; bus_exhaust = dc_out_ex;
dc_out_ec = bus_engine - dc_in_ec + dc_pole * dc_out_ec; dc_in_ec = bus_engine; bus_engine = dc_out_ec;
dc_out_g = bus_gearbox - dc_in_g + dc_pole * dc_out_g; dc_in_g = bus_gearbox; bus_gearbox = dc_out_g;
dc_out_m = bus_mech - dc_in_m + dc_pole * dc_out_m; dc_in_m = bus_mech; bus_mech = dc_out_m;
dc_out_a = bus_air - dc_in_a + dc_pole * dc_out_a; dc_in_a = bus_air; bus_air = dc_out_a;
dc_out_t = bus_bov - dc_in_t + dc_pole * dc_out_t; dc_in_t = bus_bov; bus_bov = dc_out_t;
// Road noise typically doesn't have DC but we pass it anyway for safety
dc_out_r = bus_road - dc_in_r + dc_pole * dc_out_r; dc_in_r = bus_road; bus_road = dc_out_r;
dc_out_c = bus_chassis - dc_in_c + dc_pole * dc_out_c; dc_in_c = bus_chassis; bus_chassis = dc_out_c;
dc_out_brk = bus_brakes - dc_in_brk + dc_pole * dc_out_brk; dc_in_brk = bus_brakes; bus_brakes = dc_out_brk;
dc_out_bg = bus_bangs - dc_in_bg + dc_pole * dc_out_bg; dc_in_bg = bus_bangs; bus_bangs = dc_out_bg;
dc_out_wd = bus_wind  - dc_in_wd + dc_pole * dc_out_wd; dc_in_wd = bus_wind;  bus_wind  = dc_out_wd;
dc_out_int = bus_interior - dc_in_int + dc_pole * dc_out_int; dc_in_int = bus_interior; bus_interior = dc_out_int;

// 8. Output Routing
spl0 = 0; spl1 = 0; spl2 = 0; spl3 = 0; spl4 = 0; spl5 = 0; 
spl6 = 0; spl7 = 0; spl8 = 0; spl9 = 0; spl10 = 0; spl11 = 0;
spl12 = 0; spl13 = 0; spl14 = 0; spl15 = 0;
spl16 = 0; spl17 = 0;
spl18 = 0; spl19 = 0;
spl20 = 0; spl21 = 0;
spl22 = 0; spl23 = 0;
spl24 = 0; spl25 = 0;

// Stereo Width works as controlled bus spread:
// width=0 -> previous dual-mono behavior; width=1 -> full per-bus L/R spread.
function route_out_wide(ch, val, pan) (
  pan_w = min(max(pan * width, -1.0), 1.0);
  pan_w >= 0 ? (
    val_l = val * (1.0 - pan_w);
    val_r = val;
  ) : (
    val_l = val;
    val_r = val * (1.0 + pan_w);
  );

  ch == 0 ? (spl0 += val_l; spl1 += val_r;) :
  ch == 2 ? (spl2 += val_l; spl3 += val_r;) :
  ch == 4 ? (spl4 += val_l; spl5 += val_r;) :
  ch == 6 ? (spl6 += val_l; spl7 += val_r;) :
  ch == 8 ? (spl8 += val_l; spl9 += val_r;) :
  ch == 10 ? (spl10 += val_l; spl11 += val_r;) :
  ch == 12 ? (spl12 += val_l; spl13 += val_r;) :
  ch == 16 ? (spl16 += val_l; spl17 += val_r;) :
  ch == 18 ? (spl18 += val_l; spl19 += val_r;) :
  ch == 20 ? (spl20 += val_l; spl21 += val_r;) :
  ch == 22 ? (spl22 += val_l; spl23 += val_r;) :
  ch == 24 ? (spl24 += val_l; spl25 += val_r;) :
             (spl14 += val_l; spl15 += val_r;);
);

v = vol_amp;
route_out_wide(out_exhaust, bus_exhaust * v, -0.14);
route_out_wide(out_engine, bus_engine * v, 0.08);
route_out_wide(out_gearbox, bus_gearbox * v, -0.22);
route_out_wide(out_mech, bus_mech * v, 0.24);
route_out_wide(out_air, bus_air * v, 0.34);
route_out_wide(out_bov, bus_bov * v, -0.36);
route_out_wide(out_road, bus_road * v, -0.52);
route_out_wide(out_chassis, bus_chassis * v, 0.52);
route_out_wide(out_brakes, bus_brakes * v, -0.38);
route_out_wide(out_bangs, bus_bangs * v, -0.06);
route_out_wide(out_wind,  bus_wind  * v, 0.60);
route_out_wide(out_interior, bus_interior * v, 0.0);
route_out_wide(out_siren_horn, bus_siren_horn * v, 0.0);

// Telemetry export for Lua UI
ui_speed_norm = target_veh_speed_override > 0.0 ? target_veh_speed_override : veh_speed_norm;
slider50 = min(max(cur_rpm, 0.0), 9000.0);
slider51 = min(max(ui_speed_norm * 280.0, 0.0), 280.0);
slider52 = min(max(thermal_norm * 100.0, 0.0), 100.0);
gmem[0] = slider50;
gmem[1] = slider51;
gmem[2] = slider52;

// Notify host/UI only when telemetry materially changed
(abs(slider50 - ui_prev_rpm) > 1.0 || abs(slider51 - ui_prev_spd) > 0.2 || abs(slider52 - ui_prev_tmp) > 0.2) ? (
  ui_prev_rpm = slider50;
  ui_prev_spd = slider51;
  ui_prev_tmp = slider52;
  slider_automate(50);
  slider_automate(51);
  slider_automate(52);
  sliderchange(slider50);
  sliderchange(slider51);
  sliderchange(slider52);
);

@gfx 640 350
// --- RESPONSIVE SCALING ---
sc = min(gfx_w / 640, gfx_h / 400);  
sc < 0.5 ? sc = 0.5; sc > 2.0 ? sc = 2.0;

// --- COLOR PALETTE ---
bg_r = 0.10; bg_g = 0.10; bg_b = 0.12; 
pnl_r = 0.07; pnl_g = 0.07; pnl_b = 0.08; 
acc_r = 0.20; acc_g = 0.80; acc_b = 0.40; // Cyan-green
txt_r = 0.80; txt_g = 0.80; txt_b = 0.80; // Light text
red_r = 0.90; red_g = 0.20; red_b = 0.15; // Redline

gfx_r = bg_r; gfx_g = bg_g; gfx_b = bg_b; gfx_a = 1;
gfx_rect(0, 0, gfx_w, gfx_h);

// Fonts
font_sm = max(10, (11 * sc)|0);
font_md = max(13, (16 * sc)|0);
font_lg = max(24, (34 * sc)|0);

// --- TACHOMETER LAYOUT ---
t_cx = gfx_w * 0.35; 
t_cy = gfx_h * 0.43;  // Moved up so the Ignition button has space!
t_r1 = min(gfx_w, gfx_h) * 0.33; // Outer ring (slightly smaller for compact height)
t_r0 = t_r1 * 0.7; // Inner ring

// Draw Arc Track Background
gfx_r = pnl_r+0.05; gfx_g = pnl_g+0.05; gfx_b = pnl_b+0.05; gfx_a = 1;
gfx_circle(t_cx, t_cy, t_r1, 1);
gfx_r = bg_r; gfx_g = bg_g; gfx_b = bg_b;
gfx_circle(t_cx, t_cy, t_r0, 1);

// Draw Value Needle Arc
mapped_rpm = min(cur_rpm / max(1, limiter_rpm + 500), 1.0);
a_start = -2.35619; // -135 deg
a_end   = a_start + (mapped_rpm * 4.71238); // 270 deg total sweep

n_x = t_cx + cos(a_end) * t_r1;
n_y = t_cy + sin(a_end) * t_r1;

gfx_r = acc_r; gfx_g = acc_g; gfx_b = acc_b; 
cur_rpm > limiter_rpm - 300 ? ( gfx_r=red_r; gfx_g=red_g; gfx_b=red_b; ); // Redline color

// Glow around needle
gfx_a = 0.8; gfx_circle(n_x, n_y, 8*sc, 1);
gfx_a = 0.4; gfx_circle(n_x, n_y, 14*sc, 1);
gfx_a = 1.0; gfx_circle(n_x, n_y, 4*sc, 1); // Core
gfx_line(t_cx + cos(a_end)*t_r0, t_cy + sin(a_end)*t_r0, n_x, n_y);

// RPM Text Center
gfx_setfont(1, "Arial", font_lg, 'b');
gfx_r = txt_r; gfx_g = txt_g; gfx_b = txt_b; gfx_a = 1;
rpm_str = sprintf(#, "%d", cur_rpm|0);
gfx_measurestr(rpm_str, tw, th);
gfx_x = t_cx - tw*0.5; gfx_y = t_cy - th*0.5 - 10;
gfx_drawstr(rpm_str);

gfx_setfont(1, "Arial", font_sm);
gfx_measurestr("RPM", tw, th);
gfx_x = t_cx - tw*0.5; gfx_y = t_cy + 10;
gfx_drawstr("RPM");

// --- GEAR & THROTTLE UI X/Y AREA ---
rect_x = gfx_w * 0.7;
rect_y = gfx_h * 0.1;
rect_w = gfx_w * 0.25;
rect_h = gfx_h * 0.8;

brk_w = rect_w * 0.34;
brk_x = rect_x - brk_w - 10*sc;
brk_y = rect_y;
brk_h = rect_h;

// Throttle Bar Frame
gfx_r = pnl_r+0.05; gfx_g = pnl_g+0.05; gfx_b = pnl_b+0.05; gfx_a = 1;
gfx_rect(rect_x, rect_y, rect_w, rect_h);

// Throttle Fill
gfx_r = acc_r * 0.8; gfx_g = acc_g * 0.8; gfx_b = acc_b * 0.8; 
fill_h = rect_h * cur_throttle;
gfx_rect(rect_x, rect_y + rect_h - fill_h, rect_w, fill_h);

// Brake Bar Frame
gfx_r = pnl_r+0.05; gfx_g = pnl_g+0.05; gfx_b = pnl_b+0.05; gfx_a = 1;
gfx_rect(brk_x, brk_y, brk_w, brk_h);

// Brake Fill
gfx_r = red_r * 0.9; gfx_g = red_g * 0.9; gfx_b = red_b * 0.9;
brk_fill_h = brk_h * cur_brake;
gfx_rect(brk_x, brk_y + brk_h - brk_fill_h, brk_w, brk_fill_h);

// Status Panel text
gfx_setfont(1, "Arial", font_md);
gfx_r=1; gfx_g=1; gfx_b=1; gfx_a=1;
gfx_x = rect_x + 10; gfx_y = rect_y + 10;
gear_str = gear == 0 ? "N" : sprintf(#, "%d", gear);
gfx_drawstr("GEAR: "); gfx_drawstr(gear_str);
// While braking, show physical wheel speed directly to avoid UI tail lag.
speed_meter_norm = target_veh_speed_override > 0.0
  ? target_veh_speed_override
  : (brake_speed_ctl > 0.08 && launch_intent < 0.20 ? veh_speed_raw : veh_speed_norm);
speed_kmh = speed_meter_norm * 280.0;
gfx_x = rect_x + 10; gfx_y = rect_y + 10 + font_md + 6*sc;
gfx_drawstr("SPD: "); gfx_drawstr(sprintf(#, "%d km/h", speed_kmh|0));

// Temperature indicator: cold (blue) → warm (orange) → hot (red)
gfx_r = 0.30 + thermal_norm * 0.65;
gfx_g = thermal_norm < 0.5 ? (0.52 + thermal_norm * 0.36) : max(0.0, 0.70 - (thermal_norm - 0.5) * 1.10);
gfx_b = 0.78 - thermal_norm * 0.60;
gfx_x = rect_x + 10; gfx_y = rect_y + 10 + (font_md + 6*sc) * 2;
gfx_setfont(1, "Arial", font_sm);
therm_label = thermal_norm < 0.15 ? "COLD" : (thermal_norm > 0.85 ? "HOT" : "WARM");
gfx_drawstr("TEMP: "); gfx_drawstr(therm_label);
therm_bar_x = rect_x + 10; therm_bar_y = gfx_y + font_sm + 2*sc;
therm_bar_w = rect_w - 20;
gfx_r = pnl_r + 0.10; gfx_g = pnl_g + 0.10; gfx_b = pnl_b + 0.10; gfx_a = 1;
gfx_rect(therm_bar_x, therm_bar_y, therm_bar_w, 4*sc);
gfx_r = 0.18 + thermal_norm * 0.78;
gfx_g = thermal_norm < 0.5 ? (0.38 + thermal_norm * 0.44) : max(0.0, 0.60 - (thermal_norm - 0.5) * 1.20);
gfx_b = 0.62 - thermal_norm * 0.52;
gfx_rect(therm_bar_x, therm_bar_y, therm_bar_w * thermal_norm, 4*sc);
gfx_setfont(1, "Arial", font_md);

// Ignition Button (bottom of rect or left)
ign_w = 80 * sc; ign_h = 35 * sc;
ign_x = t_cx - ign_w*0.5; ign_y = t_cy + t_r1 + 25*sc;

// Ignition button: filled rectangle
gfx_r = target_ignition ? red_r : (pnl_r+0.10);
gfx_g = target_ignition ? red_g : (pnl_g+0.10);
gfx_b = target_ignition ? red_b : (pnl_b+0.10);
gfx_roundrect(ign_x, ign_y, ign_w, ign_h, 8*sc, 0); // Filled

// Text
gfx_setfont(1, "Arial", font_md, 'b');
gfx_r = target_ignition ? 1.0 : txt_r;
gfx_g = target_ignition ? 1.0 : txt_g;
gfx_b = target_ignition ? 1.0 : txt_b;
gfx_measurestr("ENGINE STOP", mw, mh);
ign_text = target_ignition ? "STOP" : "START";
gfx_measurestr(ign_text, mw, mh);
gfx_x = ign_x + ign_w*0.5 - mw*0.5; 
gfx_y = ign_y + ign_h*0.5 - mh*0.5;
gfx_drawstr(ign_text);

// INTERACTIVITY: DRAGGING
mouse_cap == 1 && prev_mouse_cap == 0 ? (
  // Check Ignition Click
  mouse_x >= ign_x && mouse_x <= ign_x + ign_w && mouse_y >= ign_y && mouse_y <= ign_y + ign_h ? (
    slider1 = 1 - slider1; // Toggle
    target_ignition = slider1;
    sliderchange(1 << 0);
  );
);

mouse_cap & 1 ? (
  (mouse_x >= brk_x && mouse_x <= brk_x + brk_w && mouse_y >= brk_y && mouse_y <= brk_y + brk_h) || dragging_brake == 1 ? (
    dragging_brake = 1;
    brake_amt = 1.0 - ((mouse_y - brk_y) / brk_h);
    brake_amt = max(0, min(brake_amt, 1.0));
    slider3 = brake_amt * 100;
    target_brake = brake_amt;
    sliderchange(1 << 2);
  );

  (mouse_x >= rect_x && mouse_x <= rect_x + rect_w && mouse_y >= rect_y && mouse_y <= rect_y + rect_h) || dragging_gas == 1 ? (
    dragging_gas = 1;
    // Keep current mode: pedal must work in both Direct and Physics
    
    // Calculate relative gas pedal depression
    gas_amt = 1.0 - ((mouse_y - rect_y) / rect_h);
    gas_amt = max(0, min(gas_amt, 1.0));
    
    // Set slider and target immediately!
    slider2 = gas_amt * 100;
    target_throttle = gas_amt;
    sliderchange(1 << 1); // Notify host of throttle change
  );
) : (
  // Release Pedal
  dragging_brake == 1 ? (
    dragging_brake = 0;
    slider3 = 0;
    target_brake = 0;
    sliderchange(1 << 2);
  );

  dragging_gas == 1 ? (
    dragging_gas = 0;
    cur_throttle > 0.05 ? (
      slider2 = 0;
      target_throttle = 0; // Force immediate update!
      sliderchange(1 << 1);
    );
  );
);

prev_mouse_cap = mouse_cap;

// Draw Interactive Hint
gfx_x = rect_x+5; gfx_y = rect_y + rect_h + 5;
gfx_r=0.4; gfx_g=0.4; gfx_b=0.4;
gfx_setfont(1, "Arial", font_sm);
gfx_drawstr("Right bar: Gas | Left red bar: Brake");