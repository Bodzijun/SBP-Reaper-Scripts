@init
function get_gear_ratio(g) (
  g == -1 ? 3.05 : g == 1 ? 3.16 : g == 2 ? 1.88 : g == 3 ? 1.29 :
  g == 4 ? 0.97 : g == 5 ? 0.73 : g == 6 ? 0.53 : 0.0;
);

// Constants
pi = 3.14159265359;
pi2 = 2.0 * pi;

// Smooth function
function smooth_param(target, current, time_ms) (
  coeff = 1.0 - exp(-1.0 / (srate * (time_ms / 1000.0)));
  current + (target - current) * coeff;
);

// Biquad struct/functions (Simple LPF for muffler)
function biquad_lpf(freq, q) instance(c0, c1, c2, b1, b2, a1, a2, z1, z2) (
  w0 = 2 * pi * freq / srate;
  alpha = sin(w0) / (2 * q);
  cos_w0 = cos(w0);
  
  a0 = 1 + alpha;
  c0 = (1 - cos_w0) / 2 / a0;
  c1 = (1 - cos_w0) / a0;
  c2 = (1 - cos_w0) / 2 / a0;
  b1 = -2 * cos_w0 / a0;
  b2 = (1 - alpha) / a0;
);

function biquad_process(x) instance(c0, c1, c2, b1, b2, a1, a2, z1, z2) (
  out = c0 * x + c1 * z1 + c2 * z2 - b1 * a1 - b2 * a2;
  z2 = z1; z1 = x;
  a2 = a1; a1 = out;
  out;
);

// White noise
function rand_noise() ( (rand(2) - 1.0) );

